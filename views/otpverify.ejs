<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NexusSphere | Identity Verification | Secure Portal</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <style>
        :root {
            --primary: #3b82f6;
            --primary-glow: rgba(59, 130, 246, 0.5);
            --secondary: #a855f7;
            --secondary-glow: rgba(168, 85, 247, 0.5);
            --bg-dark: #050a15;
            --text-main: #eef2ff;
            --glass-bg: rgba(10, 18, 35, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: rgba(0, 0, 0, 0.6);
            --transition-elite: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            --success: #10b981;
            --error: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            cursor: default;
        }

        /* 1. Liquid Background */
        #constellationCanvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            opacity: 0.5;
        }
        .glow-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -2;
            background: 
                radial-gradient(circle at 15% 15%, rgba(59, 130, 246, 0.1), transparent 40%),
                radial-gradient(circle at 85% 85%, rgba(168, 85, 247, 0.1), transparent 40%);
            filter: blur(60px);
        }

        /* 2. Elite OTP Card */
        .otp-container {
            width: 100%;
            max-width: 500px;
            padding: 1.5rem;
            z-index: 100;
        }

        .otp-card {
            background: var(--glass-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 4rem 3rem;
            box-shadow: 0 40px 100px var(--glass-shadow);
            transform-style: preserve-3d;
            perspective: 1200px;
            position: relative;
            overflow: hidden;
            text-align: center;
        }

        /* Glass Shimmer swipe */
        .otp-card::after {
            content: ''; position: absolute; top: -150%; left: -150%; width: 300%; height: 300%;
            background: linear-gradient(135deg, transparent, rgba(255,255,255,0.03) 50%, transparent);
            transform: rotate(45deg); animation: shimmer 10s infinite linear; pointer-events: none;
        }
        @keyframes shimmer { 0% { transform: translate(-30%, -30%) rotate(45deg); } 100% { transform: translate(30%, 30%) rotate(45deg); } }

        .header { margin-bottom: 3rem; }
        
        .shield-icon-wrap {
            display: inline-block; margin-bottom: 1.5rem;
            position: relative;
        }
        .shield-icon {
            font-size: 4rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text; background-clip: text; color: transparent;
            filter: drop-shadow(0 0 20px var(--primary-glow));
        }

        h1 {
            font-size: 2.2rem; font-weight: 800; letter-spacing: -1px;
            background: linear-gradient(135deg, #fff, #94a3b8);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin-bottom: 0.75rem;
        }
        p { color: #64748b; font-size: 1rem; font-weight: 500; line-height: 1.6; }
        .email-display { color: var(--primary); font-weight: 700; letter-spacing: 0.5px; }

        /* 3. Electric OTP Slots */
        .otp-form { margin-top: 3rem; }
        
        .otp-input-wrap {
            display: flex; justify-content: space-between; gap: 12px; margin-bottom: 3rem;
        }
        
        .otp-input-wrap input {
            flex: 1; height: 70px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            text-align: center; font-size: 1.8rem; font-weight: 800;
            color: white; outline: none; transition: var(--transition-elite);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
        }
        
        /* Electric Focus States */
        .otp-input-wrap input:focus {
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--primary);
            box-shadow: 
                0 0 0 4px rgba(59, 130, 246, 0.1),
                0 0 30px rgba(59, 130, 246, 0.2);
            transform: translateY(-5px) scale(1.05);
        }
        
        .otp-input-wrap input.filled { border-color: var(--primary-glow); background: rgba(59, 130, 246, 0.05); }

        /* Verify Button */
        .btn-verify {
            width: 100%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white; border: none; border-radius: 22px; padding: 1.3rem;
            font-size: 1.1rem; font-weight: 700; cursor: pointer;
            transition: var(--transition-elite);
            display: flex; align-items: center; justify-content: center; gap: 1rem;
            text-transform: uppercase; letter-spacing: 2px;
            box-shadow: 0 15px 35px rgba(59, 130, 246, 0.3);
            position: relative;
        }
        
        .btn-verify:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 25px 50px rgba(59, 130, 246, 0.5);
            filter: brightness(1.1);
        }
        
        /* Resend Section */
        .resend-box {
            margin-top: 2.5rem; font-size: 0.95rem; color: #64748b; font-weight: 500;
        }
        
        .resend-link {
            color: var(--primary); text-decoration: none; font-weight: 800; margin-left: 0.5rem;
            transition: var(--transition-elite); cursor: pointer;
        }
        .resend-link:hover { color: white; text-shadow: 0 0 10px var(--primary-glow); }
        .resend-link.disabled { color: #475569; pointer-events: none; opacity: 0.5; }
        
        .timer { font-weight: 800; color: var(--secondary); margin-left: 0.5rem; display: inline-block; width: 40px; text-align: left; }

        /* Loader & Success Overlays */
        .overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--glass-bg); backdrop-filter: blur(20px);
            display: none; align-items: center; justify-content: center; flex-direction: column;
            z-index: 200; border-radius: 40px;
        }
        .spinner {
            width: 60px; height: 60px; border: 4px solid rgba(255,255,255,0.1); border-top-color: var(--primary);
            border-radius: 50%; animation: spin 1s infinite linear; margin-bottom: 2rem;
            filter: drop-shadow(0 0 15px var(--primary-glow));
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .success-icon { font-size: 5rem; color: var(--success); filter: drop-shadow(0 0 20px rgba(16, 185, 129, 0.4)); margin-bottom: 1.5rem; }

        @media (max-width: 767px) {
            body { height: auto; min-height: 100vh; overflow-y: auto; padding: 1.5rem 0; }
            .otp-container { max-width: 100%; padding: 1rem; }
            .otp-card { border-radius: 28px; }
        }
        @media (max-width: 480px) {
            .otp-card { padding: 2.5rem 1.2rem; border-radius: 22px; }
            .otp-input-wrap { gap: 6px; }
            .otp-input-wrap input { height: 50px; width: 42px; font-size: 1.4rem; border-radius: 10px; }
            h1 { font-size: 1.6rem; }
            .shield-icon { font-size: 3rem; }
        }
        @media (max-width: 360px) {
            .otp-input-wrap { gap: 4px; }
            .otp-input-wrap input { height: 44px; width: 36px; font-size: 1.2rem; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <canvas id="constellationCanvas"></canvas>
    <div class="glow-overlay"></div>

    <div class="otp-container">
        <div class="otp-card" id="tiltCard">
            <!-- Loader Overlay -->
            <div class="overlay" id="loadingOverlay">
                <div class="spinner"></div>
                <h2>Verifying Protocols</h2>
                <p>Syncing with Nexus Mainframe...</p>
            </div>

            <!-- Success Overlay -->
            <div class="overlay" id="successOverlay">
                <i class="fas fa-check-double success-icon"></i>
                <h2>Access Granted</h2>
                <p>Welcome, Resident. Redirecting to Terminal...</p>
            </div>

            <div class="header">
                <div class="shield-icon-wrap" id="magIcon">
                    <i class="fas fa-shield-alt shield-icon"></i>
                </div>
                <h1>Security Protocol</h1>
                <p>Enter the master key sent to <br><span class="email-display"><%= email %></span></p>
            </div>

            <form action="/verifyotp" method="POST" class="otp-form" id="otpForm">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div class="otp-input-wrap" id="otpInputs">
                    <input type="text" name="otp1" maxlength="1" pattern="\d" required autocomplete="off">
                    <input type="text" name="otp2" maxlength="1" pattern="\d" required autocomplete="off">
                    <input type="text" name="otp3" maxlength="1" pattern="\d" required autocomplete="off">
                    <input type="text" name="otp4" maxlength="1" pattern="\d" required autocomplete="off">
                    <input type="text" name="otp5" maxlength="1" pattern="\d" required autocomplete="off">
                    <input type="text" name="otp6" maxlength="1" pattern="\d" required autocomplete="off">
                </div>

                <div class="btn-wrap">
                    <button type="submit" class="btn-verify" id="verifyBtn">
                        Initiate Access <i class="fas fa-bolt"></i>
                    </button>
                </div>
            </form>

            <div class="resend-box">
                Key expired or not received? 
                <span class="resend-link" id="resendBtn">Synchronize New Key</span>
                <span class="timer" id="timerCount">60s</span>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /* 1. Liquid Background Engine */
            const canvas = document.getElementById('constellationCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouse = { x: null, y: null, radius: 150 };
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize); resize();
            window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2 + 1; this.baseX = this.x; this.baseY = this.y;
                    this.density = (Math.random() * 30) + 1;
                }
                draw() { ctx.fillStyle = 'rgba(238, 242, 255, 0.6)'; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill(); }
                update() {
                    let dx = mouse.x - this.x; let dy = mouse.y - this.y;
                    let dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < mouse.radius) {
                        let force = (mouse.radius - dist) / mouse.radius;
                        this.x -= (dx/dist) * force * this.density;
                        this.y -= (dy/dist) * force * this.density;
                    } else {
                        this.x -= (this.x - this.baseX) / 10; this.y -= (this.y - this.baseY) / 10;
                    }
                }
            }
            function init() { particles = []; for(let i=0; i<150; i++) particles.push(new Particle()); }
            function animate() {
                ctx.clearRect(0,0,canvas.width,canvas.height);
                particles.forEach(p => { p.draw(); p.update(); });
                connect(); requestAnimationFrame(animate);
            }
            function connect() {
                for(let a=0; a<particles.length; a++) {
                    for(let b=a; b<particles.length; b++) {
                        let dist = Math.sqrt(Math.pow(particles[a].x - particles[b].x, 2) + Math.pow(particles[a].y - particles[b].y, 2));
                        if(dist < 100) {
                            ctx.strokeStyle = `rgba(59,130,246,${(1 - dist/100) * 0.15})`;
                            ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(particles[a].x, particles[a].y); ctx.lineTo(particles[b].x, particles[b].y); ctx.stroke();
                        }
                    }
                }
            }
            init(); animate();

            /* 2. OTP Input Engine */
            const inputs = document.querySelectorAll('#otpInputs input');
            inputs.forEach((input, i) => {
                input.addEventListener('input', (e) => {
                    if (e.target.value.length === 1 && i < inputs.length - 1) {
                        e.target.classList.add('filled');
                        inputs[i + 1].focus();
                        gsap.from(inputs[i+1], { scale: 0.8, duration: 0.3, ease: 'back.out' });
                    }
                });
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !e.target.value && i > 0) {
                        inputs[i - 1].focus();
                        inputs[i - 1].classList.remove('filled');
                    }
                });
                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const data = e.clipboardData.getData('text').trim();
                    if (/^\d{6}$/.test(data)) {
                        data.split('').forEach((char, idx) => {
                            if (inputs[idx]) { inputs[idx].value = char; inputs[idx].classList.add('filled'); }
                        });
                        inputs[5].focus();
                    }
                });
            });

            /* 3. Magnetic & 3D Tilt Logic */
            const card = document.getElementById('tiltCard');
            card.addEventListener('mousemove', (e) => {
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left)/r.width - 0.5;
                const y = (e.clientY - r.top)/r.height - 0.5;
                gsap.to(card, { rotateX: -y * 10, rotateY: x * 10, duration: 0.5, ease: 'power2.out' });
            });
            card.addEventListener('mouseleave', () => gsap.to(card, { rotateX: 0, rotateY: 0, duration: 1, ease: 'elastic.out' }));

            const magTargets = [
                { el: document.getElementById('magIcon'), s: 0.3 },
                { el: document.getElementById('verifyBtn'), s: 0.15 },
                { el: document.getElementById('resendBtn'), s: 0.2 }
            ];
            document.addEventListener('mousemove', (e) => {
                magTargets.forEach(m => {
                    if(!m.el) return;
                    const r = m.el.getBoundingClientRect();
                    const dx = e.clientX - (r.left + r.width/2);
                    const dy = e.clientY - (r.top + r.height/2);
                    if(Math.sqrt(dx*dx + dy*dy) < 150) {
                        gsap.to(m.el, { x: dx*m.s, y: dy*m.s, duration: 0.6 });
                    } else { gsap.to(m.el, { x: 0, y: 0, duration: 1 }); }
                });
            });

            /* 4. Timer Logic */
            let timeLeft = 60;
            const timerEl = document.getElementById('timerCount');
            const resendBtn = document.getElementById('resendBtn');
            function startTimer() {
                resendBtn.classList.add('disabled');
                timeLeft = 60;
                const interval = setInterval(() => {
                    timeLeft--;
                    timerEl.innerText = timeLeft + "s";
                    if(timeLeft <= 0) {
                        clearInterval(interval);
                        resendBtn.classList.remove('disabled');
                        timerEl.innerText = "0s";
                        gsap.to(resendBtn, { scale: 1.1, repeat: 1, yoyo: true, duration: 0.3 });
                    }
                }, 1000);
            }
            startTimer();

            resendBtn.addEventListener('click', () => {
                if(!resendBtn.classList.contains('disabled')) {
                    gsap.from(resendBtn, { opacity: 0, duration: 0.5 });
                    // Simulate resend
                    startTimer();
                }
            });

            /* 5. Form Submission & Overlays */
            const form = document.getElementById('otpForm');
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const otp = Array.from(inputs).map(i => i.value).join('');
                if(otp.length < 6) {
                    gsap.to(card, { x: -10, repeat: 3, yoyo: true, duration: 0.05, onComplete: () => gsap.to(card, {x:0}) });
                    return;
                }

                document.getElementById('loadingOverlay').style.display = 'flex';
                gsap.from('#loadingOverlay > *', { y: 20, opacity: 0, stagger: 0.2, duration: 0.8 });

                // Simulate backend verify
                setTimeout(() => {
                    document.getElementById('loadingOverlay').style.display = 'none';
                    document.getElementById('successOverlay').style.display = 'flex';
                    gsap.from('#successOverlay i', { scale: 0.5, opacity: 0, rotate: -45, duration: 0.8, ease: 'back.out' });
                    
                    setTimeout(() => {
                        // Create combined OTP hidden input for actual submission
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden'; hidden.name = 'otp'; hidden.value = otp;
                        form.appendChild(hidden);
                        form.submit();
                    }, 2000);
                }, 2500);
            });
        });
    </script>
</body>
</html>
