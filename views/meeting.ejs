<%- include("../utils/header") %>

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <!-- AOS Animation -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

  <style>
    :root {
      --primary-color: #6366f1;
      --primary-light: #a5b4fc;
      --secondary-color: #8b5cf6;
      --accent-color: #ec4899;
      --success-color: #10b981;
      --info-color: #3b82f6;
      --warning-color: #f59e0b;
      --danger-color: #ef4444;
      --dark-color: #1e293b;
      --light-color: #f8fafc;
      --card-radius: 20px;
      --transition-speed: 0.3s;
      --glass-bg: rgba(255, 255, 255, 0.7);
      --glass-border: rgba(255, 255, 255, 0.3);
    }

    body.dark-mode {
      --glass-bg: rgba(30, 41, 59, 0.7);
      --glass-border: rgba(255, 255, 255, 0.1);
      background-color: #0f172a;
      color: #e2e8f0;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f3f4f6;
      transition: background-color 0.5s ease;
    }

    #main {
      margin-left: 280px;
      /* Adjust based on sidebar width */
      transition: margin-left 0.3s ease;
      padding: 20px;
    }

    @media (max-width: 991px) {
      #main {
        margin-left: 0;
      }
    }

    /* Glassmorphism Cards */
    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid var(--glass-border);
      border-radius: var(--card-radius);
      box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
      transition: transform var(--transition-speed) ease, box-shadow var(--transition-speed) ease;
      overflow: hidden;
    }

    .glass-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.12);
    }

    /* Stat Cards */
    .stat-card {
      padding: 1.5rem;
      position: relative;
      z-index: 1;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, var(--primary-light) 0%, transparent 70%);
      opacity: 0.1;
      z-index: -1;
      border-radius: 50%;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1rem;
      transition: transform 0.3s ease;
    }

    .stat-card:hover .stat-icon {
      transform: scale(1.1) rotate(5deg);
    }

    /* Meeting Item */
    .meeting-item {
      padding: 1rem;
      border-bottom: 1px solid var(--glass-border);
      transition: background 0.3s ease;
      cursor: pointer;
    }

    .meeting-item:last-child {
      border-bottom: none;
    }

    .meeting-item:hover {
      background: rgba(99, 102, 241, 0.05);
    }

    .status-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .status-scheduled {
      background: rgba(59, 130, 246, 0.1);
      color: #3b82f6;
    }

    .status-completed {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }

    .status-canceled {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
    }

    /* Map Container */
    #map {
      height: 300px;
      width: 100%;
      border-radius: 12px;
      margin-top: 1rem;
      display: none;
      border: 1px solid var(--glass-border);
    }

    /* Custom Inputs */
    .form-control,
    .form-select {
      border-radius: 10px;
      padding: 0.75rem 1rem;
      border: 1px solid var(--glass-border);
      background: rgba(255, 255, 255, 0.5);
      transition: all 0.3s ease;
    }

    .form-control:focus,
    .form-select:focus {
      background: #fff;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
      border-color: var(--primary-color);
    }

    .dark-mode .form-control,
    .dark-mode .form-select {
      background: rgba(30, 41, 59, 0.5);
      color: #fff;
    }

    /* Floating Action Button for Mobile */
    .fab {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: var(--primary-color);
      color: #fff;
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
      z-index: 1000;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .fab:hover {
      transform: scale(1.1) rotate(90deg);
    }

    @media (max-width: 767px) {
      .fab {
        display: flex;
      }
    }

    /* Navigation Tabs */
    .nav-tabs {
      border: none;
      margin-bottom: 2rem;
    }

    .nav-link-custom {
      color: var(--dark-color);
      border: none;
      padding: 10px 20px;
      border-radius: 10px;
      margin-right: 10px;
      font-weight: 500;
      transition: all 0.3s ease;
    }

    .dark-mode .nav-link-custom {
      color: #e2e8f0;
    }

    .nav-link-custom.active {
      background: var(--primary-color);
      color: #fff !important;
    }

    .category-pill {
      font-size: 0.7rem;
      padding: 2px 8px;
      border-radius: 10px;
      background: rgba(0, 0, 0, 0.05);
      margin-left: 5px;
    }

    .dark-mode .category-pill {
      background: rgba(255, 255, 255, 0.05);
    }
  </style>

  <%- include("side") %>

    <main id="main">
      <div class="container-fluid p-0">
        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
          <div>
            <h2 class="fw-bold mb-1">Meeting Control Center</h2>
            <p class="text-muted">Organize, track, and manage your neural network meetings</p>
          </div>
          <div class="d-none d-md-block">
            <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm" data-bs-toggle="modal"
              data-bs-target="#scheduleModal">
              <i class="bi bi-plus-lg me-2"></i>New Meeting
            </button>
          </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-4" data-aos="fade-up">
          <div class="col-6 col-lg-3">
            <div class="glass-card stat-card">
              <div class="stat-icon bg-primary text-white">
                <i class="bi bi-calendar-event"></i>
              </div>
              <h4 class="fw-bold mb-0">
                <%= locals.stats ? stats.total : 0 %>
              </h4>
              <span class="small text-muted">Total Events</span>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="glass-card stat-card">
              <div class="stat-icon bg-info text-white">
                <i class="bi bi-clock-history"></i>
              </div>
              <h4 class="fw-bold mb-0">
                <%= locals.stats ? stats.upcoming : 0 %>
              </h4>
              <span class="small text-muted">Upcoming</span>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="glass-card stat-card">
              <div class="stat-icon bg-success text-white">
                <i class="bi bi-check2-circle"></i>
              </div>
              <h4 class="fw-bold mb-0">
                <%= locals.stats ? stats.completed : 0 %>
              </h4>
              <span class="small text-muted">Completed</span>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="glass-card stat-card">
              <div class="stat-icon bg-danger text-white">
                <i class="bi bi-x-circle"></i>
              </div>
              <h4 class="fw-bold mb-0">
                <%= locals.stats ? stats.canceled : 0 %>
              </h4>
              <span class="small text-muted">Canceled</span>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <!-- Meetings List -->
          <div class="col-lg-7" data-aos="fade-right">
            <div class="glass-card h-100 p-4">
              <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Scheduled Meetings</h5>
                <div class="input-group w-50">
                  <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                  <input type="text" id="meetingSearch" class="form-control border-start-0 ps-0"
                    placeholder="Search title...">
                </div>
              </div>

              <div class="meeting-list" id="meetingListContainer">
                <% if (locals.meetings && meetings.length> 0) { %>
                  <% meetings.forEach(meeting=> { %>
                    <div class="meeting-item d-flex align-items-center mb-2 rounded-3"
                      data-status="<%= meeting.status %>" data-title="<%= meeting.title.toLowerCase() %>">
                      <div class="me-3 text-center" style="min-width: 60px;">
                        <span class="d-block fw-bold text-primary">
                          <%= new Date(meeting.dateTime).getDate() %>
                        </span>
                        <span class="small text-uppercase">
                          <%= new Date(meeting.dateTime).toLocaleString('default', { month: 'short' }) %>
                        </span>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="fw-bold mb-0">
                          <%= meeting.title %> <span class="category-pill">
                              <%= meeting.category %>
                            </span>
                        </h6>
                        <small class="text-muted d-block">
                          <i class="bi bi-clock me-1"></i>
                          <%= new Date(meeting.dateTime).toLocaleTimeString([], { hour: '2-digit' , minute: '2-digit' })
                            %>
                            • <i
                              class="bi <%= meeting.meetingType === 'online' ? 'bi-laptop' : 'bi-geo-alt' %> ms-2 me-1"></i>
                            <%= meeting.meetingType==='online' ? meeting.locationDetails.online.platform :
                              meeting.locationDetails.offline.address %>
                        </small>
                        <% if (meeting.meetingType==='online' && meeting.locationDetails.online.link) { %>
                          <a href="<%= meeting.locationDetails.online.link %>" target="_blank"
                            class="btn btn-sm btn-outline-primary mt-2 py-0 px-2" style="font-size: 0.7rem;">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Join Now
                          </a>
                          <% } %>
                      </div>
                      <div class="text-end">
                        <span class="status-badge status-<%= meeting.status %> d-block mb-1">
                          <%= meeting.status %>
                        </span>
                        <button class="btn btn-link btn-sm text-muted p-0"
                          onclick="showMeetingDetails('<%= meeting._id %>')">Details</button>
                      </div>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <div class="text-center py-5">
                          <i class="bi bi-calendar-x display-4 text-muted mb-3 d-block"></i>
                          <p class="text-muted">No meetings scheduled yet</p>
                          <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                            data-bs-target="#scheduleModal">Schedule Now</button>
                        </div>
                        <% } %>
              </div>
            </div>
          </div>

          <!-- Quick Schedule Form (Hidden on mobile, uses Modal) -->
          <div class="col-lg-5 d-none d-lg-block" data-aos="fade-left">
            <div class="glass-card p-4">
              <h5 class="fw-bold mb-4"><i class="bi bi-patch-plus me-2 text-primary"></i>Express Scheduler</h5>
              <form id="meetingFormSide" action="/create_meeting" method="POST">
                <div class="mb-3">
                  <label class="form-label small fw-bold">Meeting Title</label>
                  <input type="text" name="title" class="form-control" placeholder="Project Sync" required>
                </div>
                <div class="mb-3">
                  <label class="form-label small fw-bold">Date & Time</label>
                  <input type="datetime-local" name="dateTime" class="form-control" required>
                </div>
                <div class="mb-3">
                  <label class="form-label small fw-bold">Category</label>
                  <select name="meetingCategory" class="form-select" required>
                    <option value="training">Training</option>
                    <option value="recruitment">Recruitment</option>
                    <option value="team" selected>Team Meeting</option>
                    <option value="product">Product Launch</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label small fw-bold">Mode</label>
                  <div class="btn-group w-100" role="group">
                    <input type="radio" class="btn-check" name="meetingMode" id="modeOnline" value="online" checked
                      autocomplete="off">
                    <label class="btn btn-outline-primary" for="modeOnline"><i
                        class="bi bi-laptop me-2"></i>Online</label>
                    <input type="radio" class="btn-check" name="meetingMode" id="modeOffline" value="offline"
                      autocomplete="off">
                    <label class="btn btn-outline-primary" for="modeOffline"><i
                        class="bi bi-geo-alt me-2"></i>Offline</label>
                  </div>
                </div>
                <div id="onlineFields">
                  <div class="mb-3">
                    <label class="form-label small fw-bold">Platform</label>
                    <select name="meetingPlatform" class="form-select">
                      <option value="zoom">Zoom</option>
                      <option value="google_meet" selected>Google Meet</option>
                      <option value="teams">Microsoft Teams</option>
                      <option value="other">Other Link</option>
                    </select>
                  </div>
                  <div class="mb-3" id="linkField" style="display:none;">
                    <input type="url" name="meetingLink" class="form-control" placeholder="https://...">
                  </div>
                </div>
                <div id="offlineFields" style="display:none;">
                  <div class="mb-3">
                    <label class="form-label small fw-bold">Address</label>
                    <input type="text" id="meetingAddress" name="meetingAddress" class="form-control"
                      placeholder="Search location...">
                    <div id="map"></div>
                  </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Schedule Event</button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile FAB -->
      <div class="fab" data-bs-toggle="modal" data-bs-target="#scheduleModal">
        <i class="bi bi-plus-lg"></i>
      </div>

      <!-- Schedule Modal (For Mobile/Quick Access) -->
      <div class="modal fade" id="scheduleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content glass-card border-0">
            <div class="modal-header border-0 pb-0">
              <h5 class="modal-title fw-bold">Schedule Meeting</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <form action="/create_meeting" method="POST">
                <!-- Duplicate form fields for modal -->
                <div class="mb-3">
                  <label class="form-label small fw-bold">Title</label>
                  <input type="text" name="title" class="form-control" required>
                </div>
                <div class="row g-2 mb-3">
                  <div class="col-6">
                    <label class="form-label small fw-bold">Category</label>
                    <select name="meetingCategory" class="form-select">
                      <option value="team">Team</option>
                      <option value="training">Training</option>
                    </select>
                  </div>
                  <div class="col-6">
                    <label class="form-label small fw-bold">Mode</label>
                    <select name="meetingMode" class="form-select" id="modalModeToggle">
                      <option value="online">Online</option>
                      <option value="offline">Offline</option>
                    </select>
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label small fw-bold">Date & Time</label>
                  <input type="datetime-local" name="dateTime" class="form-control" required>
                </div>
                <div id="modalOnlineFields">
                  <div class="mb-3">
                    <label class="form-label small fw-bold">Platform</label>
                    <select name="meetingPlatform" class="form-select">
                      <option value="zoom">Zoom</option>
                      <option value="google_meet" selected>Google Meet</option>
                      <option value="other">Other Link</option>
                    </select>
                  </div>
                </div>
                <div id="modalOfflineFields" style="display:none;">
                  <div class="mb-3">
                    <label class="form-label small fw-bold">Address</label>
                    <input type="text" name="meetingAddress" class="form-control" placeholder="Office / Location">
                  </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Schedule Event</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>



    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
      try {
        AOS.init({ duration: 800, once: true });
      } catch (e) { console.error("AOS init failed:", e); }

      // Mode Toggle Logic (Side Form) - Only targets radios
      const modeRadios = document.querySelectorAll('#meetingFormSide input[name="meetingMode"]');

      modeRadios.forEach(radio => {
        radio.addEventListener('change', (e) => {
          const isOnline = e.target.value === 'online';
          document.getElementById('onlineFields').style.display = isOnline ? 'block' : 'none';
          document.getElementById('offlineFields').style.display = isOnline ? 'none' : 'block';
          const mapDiv = document.getElementById('map');
          if (mapDiv) mapDiv.style.display = isOnline ? 'none' : 'block';
          if (!isOnline && map) google.maps.event.trigger(map, 'resize');
        });
      });

      // Platform Toggle Logic
      document.querySelector('#meetingFormSide select[name="meetingPlatform"]')?.addEventListener('change', (e) => {
        const linkField = document.getElementById('linkField');
        if (linkField) linkField.style.display = e.target.value === 'other' ? 'block' : 'none';
      });

      // Search Logic
      document.getElementById('meetingSearch')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.meeting-item').forEach(item => {
          const title = item.getAttribute('data-title') || '';
          item.style.display = title.includes(term) ? 'flex' : 'none';
        });
      });

      // Google Maps Integration
      let map, marker, autocomplete, geocoder;
      function initMap() {
        const mapElement = document.getElementById('map');
        if (!mapElement) return;
        map = new google.maps.Map(mapElement, {
          center: { lat: 20.5937, lng: 78.9629 },
          zoom: 5,
          styles: [{ "featureType": "all", "elementType": "labels.text.fill", "stylers": [{ "saturation": 36 }, { "color": "#333333" }, { "lightness": 40 }] }]
        });

        autocomplete = new google.maps.places.Autocomplete(document.getElementById('meetingAddress'), { types: ['geocode'] });
        autocomplete.addListener('place_changed', () => {
          const place = autocomplete.getPlace();
          if (!place.geometry) return;
          map.setCenter(place.geometry.location);
          map.setZoom(17);
          if (marker) marker.setMap(null);
          marker = new google.maps.Marker({ position: place.geometry.location, map, draggable: true });
        });
      }

      // Show Meeting Details
      function showMeetingDetails(meetingId) {
        // In a real app, this might fetch from an API. For now, we'll use an alert or find the data in the DOM.
        const item = document.querySelector(`.meeting-item[data-title]`); // This is a bit generic, but it's for demo
        alert("Meeting details functionality is being synchronized with the neural network. More features coming soon!");
      }

      // Sync Modal Toggles
      document.getElementById('modalModeToggle')?.addEventListener('change', (e) => {
        const isOnline = e.target.value === 'online';
        document.getElementById('modalOnlineFields').style.display = isOnline ? 'block' : 'none';
        document.getElementById('modalOfflineFields').style.display = isOnline ? 'none' : 'block';
      });

    </script>

    <script
      src="https://maps.googleapis.com/maps/api/js?key=AIzaSyB-B3o9cuaDBoEzeb4-Mdxo5FNCMWGaz6s&libraries=places&callback=initMap"
      async defer></script>



    <%- include("../utils/footer") %>
      </main>
      </body>

      </html>