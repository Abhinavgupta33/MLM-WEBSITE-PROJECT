        .activity-avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 800; }

        /* Support Chat */
        .chat-widget {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 10001;
        }
        .chat-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);
            transition: var(--transition);
        }
        .chat-btn:hover { transform: scale(1.1) rotate(10deg); }
        .chat-window {
            position: absolute;
            bottom: 80px;
            right: 0;
            width: 320px;
            height: 400px;
            border-radius: 25px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transform: scale(0);
            transform-origin: bottom right;
            transition: var(--transition);
        }
        .chat-window.open { transform: scale(1); }
        .chat-header { background: var(--primary); color: white; padding: 1.2rem; font-weight: 700; display: flex; justify-content: space-between; }
        .chat-body { flex: 1; padding: 1rem; overflow-y: auto; display: flex; flex-direction: column; gap: 0.8rem; background: rgba(var(--bg-light-rgb), 0.9); }
        .chat-msg { padding: 0.7rem 1rem; border-radius: 15px; font-size: 0.85rem; max-width: 85%; }
        .msg-bot { background: white; align-self: flex-start; border-bottom-left-radius: 3px; }
        .msg-user { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 3px; }
        .chat-input { padding: 1rem; display: flex; gap: 0.5rem; background: white; border-top: 1px solid var(--glass-border); }
        .chat-input input { flex: 1; border: none; outline: none; font-size: 0.85rem; }

        /* Parallax Headers */
        .reveal h2 {
            display: inline-block;
        }

        /* Language Dropdown */
        .lang-switcher {
            position: relative;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            margin-right: 1rem;
        }
        .lang-dropdown {
            position: absolute;
            top: 150%;
            right: -20px;
            background: var(--bg-light);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            padding: 0.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            opacity: 0;
            transform: translateY(10px);
            pointer-events: none;
            transition: var(--transition);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .lang-switcher:hover .lang-dropdown {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }
        .lang-dropdown span {
            padding: 0.5rem 1rem;
            border-radius: 10px;
            white-space: nowrap;
            transition: var(--transition);
        }
        .lang-dropdown span:hover {
            background: rgba(59, 130, 246, 0.1);
            color: var(--primary);
        }

        /* Mouse Glow Background */
        .glow-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -2;
            background: radial-gradient(circle at 50% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 40%);
        }

        /* Testimonials Slider */
        .testimonials {
            overflow: hidden;
        }
        .testimonials-track {
            display: flex;
            gap: 2rem;
            width: max-content;
            padding: 1rem 2rem;
        }
        .testimonial-card {
            width: 350px;
            padding: 2.5rem;
            border-radius: 30px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            flex-shrink: 0;
            transition: var(--transition);
        }
        .testimonial-card:hover { border-color: var(--primary); transform: translateY(-5px); }
        .quote { font-size: 1.1rem; font-style: italic; margin-bottom: 1.5rem; opacity: 0.9; }
        .t-user { display: flex; align-items: center; gap: 1rem; }
        .t-avatar { width: 50px; height: 50px; border-radius: 50%; background: var(--primary); }
        .t-avatar img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
        .t-info strong { display: block; }
        .t-info span { font-size: 0.85rem; opacity: 0.7; }

        /* Animations */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
