                width: 100%;
                border-radius: 0;
                top: 0;
                left: 0;
                transform: none;
            }

            .hero {
                flex-direction: column;
                text-align: center;
                padding-top: 10rem;
            }

            .hero-content p {
                margin: 1rem auto 3rem;
            }

            .hero-btns {
                justify-content: center;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .features-grid {
                grid-template-columns: 1fr;
            }

            .about-grid {
                flex-direction: column;
            }

            .pricing-grid {
                grid-template-columns: 1fr;
            }

            .contact-grid {
                grid-template-columns: 1fr;
                gap: 3rem;
            }

            .pricing-card.featured {
                transform: scale(1);
            }
        }

        /* Profit Calculator */
        .calculator-card {
            max-width: 600px;
            margin: 3rem auto 0;
            padding: 2.5rem;
            border-radius: 30px;
        }
        .calc-slider {
            width: 100%;
            height: 6px;
            background: var(--glass-border);
            border-radius: 10px;
            outline: none;
            -webkit-appearance: none;
            margin: 1.5rem 0;
        }
        .calc-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 24px;
            height: 24px;
            background: var(--primary);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 15px var(--primary);
        }
        .calc-result {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary);
            margin-top: 1rem;
        }

        /* Activity Feed */
        .activity-feed {
            position: fixed;
            bottom: 6rem;
            right: 2rem;
            z-index: 9999;
            pointer-events: none;
        }
        .activity-toast {
            background: rgba(var(--bg-dark-rgb), 0.8);
