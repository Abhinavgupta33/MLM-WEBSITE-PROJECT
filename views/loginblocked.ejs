<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexusSphere | Account Status | Security Lockdown</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <style>
        :root {
            --primary: #f59e0b;
            --primary-glow: rgba(245, 158, 11, 0.4);
            --error: #ef4444;
            --bg-dark: #050a15;
            --text-main: #eef2ff;
            --glass-bg: rgba(15, 12, 10, 0.85);
            --glass-border: rgba(245, 158, 11, 0.2);
            --glass-shadow: rgba(0, 0, 0, 0.8);
            --transition-elite: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        #constellationCanvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.4;
        }
        .glow-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
            background: radial-gradient(circle at 50% 50%, rgba(245, 158, 11, 0.1), transparent 60%);
            filter: blur(80px);
        }

        .container { width: 100%; max-width: 480px; padding: 1.5rem; z-index: 100; }

        .block-card {
            background: var(--glass-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 4rem 3rem;
            box-shadow: 0 40px 100px var(--glass-shadow);
            transform-style: preserve-3d;
            perspective: 1200px;
            position: relative;
            text-align: center;
        }

        .icon-wrap { margin-bottom: 2rem; position: relative; }
        .lock-icon {
            font-size: 5rem;
            background: linear-gradient(135deg, var(--primary), var(--error));
            -webkit-background-clip: text; background-clip: text; color: transparent;
            filter: drop-shadow(0 0 25px var(--primary-glow));
        }

        h1 {
            font-size: 2.2rem; font-weight: 800; letter-spacing: -1px;
            background: linear-gradient(135deg, #fff, #fcd34d);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin-bottom: 1rem;
        }
        p { color: #94a3b8; font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; }

        .contact-box {
            background: rgba(245, 158, 11, 0.05);
            border: 1px solid rgba(245, 158, 11, 0.1);
            border-radius: 24px;
            padding: 1.5rem;
            margin-bottom: 2.5rem;
            text-align: left;
        }
        .contact-header { 
            font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--primary); font-weight: 800; margin-bottom: 0.5rem;
        }
        .admin-email { font-weight: 600; color: #cbd5e1; font-size: 1rem; display: flex; align-items: center; gap: 0.75rem; }
        .admin-email i { color: var(--primary); }

        .btn-return {
            width: 100%;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e2e8f0; border-radius: 20px; padding: 1.2rem;
            font-size: 1rem; font-weight: 700; cursor: pointer;
            transition: var(--transition-elite);
            display: flex; align-items: center; justify-content: center; gap: 1rem;
            text-decoration: none;
        }
        .btn-return:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: white; color: white;
            transform: translateY(-5px);
        }

        .alert-bar {
            position: absolute; top: 0; left: 0; width: 100%; height: 6px;
            background: linear-gradient(90deg, var(--primary), var(--error), var(--primary));
            background-size: 200% 100%;
            animation: moveGradient 3s linear infinite;
        }
        @keyframes moveGradient { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

        .security-stamp {
            margin-top: 2rem; font-size: 0.8rem; color: #4b5563; font-weight: 600;
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        }
        @media (max-width: 767px) {
            body { height: auto; min-height: 100vh; overflow-y: auto; padding: 1.5rem 0; }
        }
        @media (max-width: 480px) {
            .blocked-card { padding: 2.5rem 1.2rem; border-radius: 22px; }
            .blocked-container { max-width: 100%; padding: 1rem; }
            h1 { font-size: 1.5rem; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <canvas id="constellationCanvas"></canvas>
    <div class="glow-overlay"></div>

    <div class="container">
        <div class="block-card" id="tiltCard">
            <div class="alert-bar"></div>
            <div class="icon-wrap" id="magIcon">
                <i class="fas fa-user-shield lock-icon"></i>
            </div>
            <h1>Account Frozen</h1>
            <p>Multiple security breaches detected. This terminal has been temporarily restricted for your protection.</p>

            <div class="contact-box">
                <div class="contact-header">Security clearance required</div>
                <div class="admin-email">
                    <i class="fas fa-envelope-open-text"></i>
                    ag9108074@gmail.com
                </div>
            </div>

            <a href="/" class="btn-return" id="returnBtn">
                <i class="fas fa-arrow-left"></i> Return to Main Registry
            </a>

            <div class="security-stamp">
                <i class="fas fa-fingerprint"></i> SECURE-ID: 7749-BX-LOCKED
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('constellationCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouse = { x: null, y: null, radius: 150 };
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize); resize();
            window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2 + 1; this.baseX = this.x; this.baseY = this.y;
                    this.density = (Math.random() * 30) + 1;
                }
                draw() { ctx.fillStyle = 'rgba(245, 158, 11, 0.4)'; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill(); }
                update() {
                    let dx = mouse.x - this.x; let dy = mouse.y - this.y;
                    let dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < mouse.radius) {
                        let force = (mouse.radius - dist) / mouse.radius;
                        this.x -= (dx/dist) * force * this.density;
                        this.y -= (dy/dist) * force * this.density;
                    } else {
                        this.x -= (this.x - this.baseX) / 10; this.y -= (this.y - this.baseY) / 10;
                    }
                }
            }
            function init() { for(let i=0; i<60; i++) particles.push(new Particle()); }
            function animate() {
                ctx.clearRect(0,0,canvas.width,canvas.height);
                particles.forEach(p => { p.draw(); p.update(); });
                connect(); requestAnimationFrame(animate);
            }
            function connect() {
                for(let a=0; a<particles.length; a++) {
                    for(let b=a; b<particles.length; b++) {
                        let dist = Math.sqrt(Math.pow(particles[a].x - particles[b].x, 2) + Math.pow(particles[a].y - particles[b].y, 2));
                        if(dist < 150) {
                            ctx.strokeStyle = `rgba(245,158,11,${(1 - dist/150) * 0.1})`;
                            ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(particles[a].x, particles[a].y); ctx.lineTo(particles[b].x, particles[b].y); ctx.stroke();
                        }
                    }
                }
            }
            init(); animate();

            const card = document.getElementById('tiltCard');
            card.addEventListener('mousemove', (e) => {
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left)/r.width - 0.5;
                const y = (e.clientY - r.top)/r.height - 0.5;
                gsap.to(card, { rotateX: -y * 8, rotateY: x * 8, duration: 0.5 });
            });
            card.addEventListener('mouseleave', () => gsap.to(card, { rotateX: 0, rotateY: 0, duration: 1, ease: 'elastic.out' }));

            const targets = [
                { el: document.getElementById('magIcon'), s: 0.3 },
                { el: document.getElementById('returnBtn'), s: 0.15 }
            ];
            document.addEventListener('mousemove', (e) => {
                targets.forEach(t => {
                    const r = t.el.getBoundingClientRect();
                    const dx = e.clientX - (r.left + r.width/2);
                    const dy = e.clientY - (r.top + r.height/2);
                    if(Math.sqrt(dx*dx + dy*dy) < 150) {
                        gsap.to(t.el, { x: dx*t.s, y: dy*t.s, duration: 0.6 });
                    } else { gsap.to(t.el, { x: 0, y: 0, duration: 1 }); }
                });
            });

            gsap.from(card, { y: 50, opacity: 0, duration: 1.2, ease: 'power4.out' });
        });
    </script>
</body>
</html>
