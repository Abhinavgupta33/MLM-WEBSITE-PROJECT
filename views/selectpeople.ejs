<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Select Participants | Nexus Console</title>
    <!-- CSS & Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.4);
            --text-main: #1e293b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            color: var(--text-main);
            overflow-x: hidden;
            margin: 0;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            min-height: 100vh;
            transition: all 0.3s ease;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 1.25rem;
            box-shadow: 0 8px 32px rgba(31, 38, 135, 0.07);
            padding: 1.5rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .meeting-info-header {
            background: var(--primary-gradient);
            color: white;
            border-radius: 1.25rem;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.2);
        }

        .user-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            transition: all 0.2s ease;
            cursor: pointer;
            position: relative;
        }

        .user-card:hover {
            border-color: #6366f1;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .user-card.selected {
            background: #f5f3ff;
            border-color: #a855f7;
        }

        .user-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 1rem;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: #6366f1;
        }

        .user-details h6 { margin: 0; font-weight: 600; }
        .user-details span { font-size: 0.8rem; color: #64748b; }

        .custom-checkbox {
            width: 22px;
            height: 22px;
            border: 2px solid #cbd5e1;
            border-radius: 6px;
            margin-left: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .selected .custom-checkbox {
            background: var(--primary-gradient);
            border-color: transparent;
        }

        .selected .custom-checkbox::after {
            content: "\F26E";
            font-family: "bootstrap-icons";
            color: white;
            font-size: 14px;
        }

        #selectAllBtn {
            font-size: 0.85rem;
            padding: 0.4rem 1rem;
            border-radius: 2rem;
        }

        .invite-footer {
            position: sticky;
            bottom: 2rem;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 1rem;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 -5px 25px rgba(0,0,0,0.05);
            z-index: 100;
        }

        .loading-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 255, 255, 0.8);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            backdrop-filter: blur(5px);
        }

        @media (max-width: 992px) {
            .main-content { margin-left: 0; padding: 1rem; }
        }
    </style>
</head>
<body>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <h5 class="fw-bold">Encrypting Invitations...</h5>
        <p class="text-muted small">Synchronizing with neural nodes</p>
    </div>

    <%- include('side') %>

    <div class="main-content">
        <%- include('../utils/header') %>

        <div class="container-fluid py-4">
            <div class="meeting-info-header" data-aos="fade-down">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-white text-primary me-2">Step 2 of 2</span>
                    <h5 class="mb-0 opacity-75">Invitation Matrix</h5>
                </div>
                <h1 class="fw-bold mb-3"><%= meetingTitle %></h1>
                <div class="d-flex flex-wrap gap-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-calendar3 me-2"></i>
                        <span><%= meetingDateTime %></span>
                    </div>
                    <div class="d-flex align-items-center ms-md-4">
                        <i class="bi bi-geo-alt me-2"></i>
                        <span><%= locals.locationText || '---' %></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="glass-card mb-4" data-aos="fade-up">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">Select Participants</h5>
                            <button class="btn btn-outline-primary btn-sm" id="selectAllBtn">Select All Team</button>
                        </div>

                        <div class="row g-3" id="userContainer">
                            <% users.forEach(user => { %>
                                <div class="col-md-6">
                                    <div class="user-card" onclick="toggleUser(this, '<%= user.user_id %>', '<%= user.email %>')">
                                        <% if(user.picture) { %>
                                            <img src="<%= user.picture %>" alt="<%= user.your_name %>" class="user-avatar">
                                        <% } else { %>
                                            <div class="user-avatar"><%= user.your_name.charAt(0) %></div>
                                        <% } %>
                                        <div class="user-details">
                                            <h6><%= user.your_name %></h6>
                                            <span><%= user.email %></span>
                                            <div class="small text-muted mt-1"><i class="bi bi-shield-check me-1"></i><%= user.user_id %></div>
                                        </div>
                                        <div class="custom-checkbox"></div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="glass-card sticky-top" style="top: 100px;" data-aos="fade-left">
                        <h5 class="fw-bold mb-3">Invite Summary</h5>
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Selected</span>
                                <span class="fw-bold" id="selectedCount">0</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Capacity</span>
                                <span class="fw-bold">Unlimited</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Total Team</span>
                                <span class="fw-bold text-primary"><%= users.length %></span>
                            </div>
                        </div>

                        <div class="alert alert-info border-0 bg-info bg-opacity-10 small mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            An automated invitation link will be securely transmitted to all selected recipients.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="invite-footer" data-aos="fade-up">
            <div class="d-flex align-items-center">
                <button class="btn btn-link text-muted me-3" onclick="window.history.back()">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </button>
            </div>
            <div>
                <button class="btn btn-primary px-5 py-2 fw-bold" id="sendInviteBtn" disabled onclick="sendInvitations()">
                    Initialize Invitation Flow <i class="bi bi-send-fill ms-2"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Hidden form for meetingId -->
    <input type="hidden" id="meetingId" value="<%= meetingId %>">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        try {
            AOS.init();
        } catch (e) { console.error("AOS init failed:", e); }

        const selectedUsers = new Set();
        const userEmails = new Map();

        function toggleUser(element, id, email) {
            if (selectedUsers.has(id)) {
                selectedUsers.delete(id);
                userEmails.delete(id);
                element.classList.remove('selected');
            } else {
                selectedUsers.add(id);
                userEmails.set(id, email);
                element.classList.add('selected');
            }
            updateSummary();
        }

        function updateSummary() {
            document.getElementById('selectedCount').textContent = selectedUsers.size;
            document.getElementById('sendInviteBtn').disabled = selectedUsers.size === 0;
        }

        document.getElementById('selectAllBtn').addEventListener('click', function() {
            const cards = document.querySelectorAll('.user-card');
            const allSelected = selectedUsers.size === cards.length;
            
            cards.forEach(card => {
                const id = card.getAttribute('onclick').match(/'([^']+)'/)[1];
                const email = card.getAttribute('onclick').match(/'[^']+', '([^']+)'/)[1];
                
                if (allSelected) {
                    card.classList.remove('selected');
                    selectedUsers.delete(id);
                    userEmails.delete(id);
                } else {
                    card.classList.add('selected');
                    selectedUsers.add(id);
                    userEmails.set(id, email);
                }
            });
            this.textContent = allSelected ? 'Select All Team' : 'Deselect All';
            updateSummary();
        });

        async function sendInvitations() {
            const overlay = document.getElementById('loadingOverlay');
            overlay.style.display = 'flex';
            
            const meetingId = document.getElementById('meetingId').value;
            const emails = Array.from(userEmails.values());
            
            const formData = {
                meetingId: meetingId,
                recipients: emails,
                subject: `Invitation: <%= meetingTitle %>`,
                message: `
                    <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden;">
                        <div style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); color: white; padding: 20px; text-align: center;">
                            <h1 style="margin: 0;">Meeting Invitation</h1>
                        </div>
                        <div style="padding: 30px; color: #1e293b;">
                            <p>Hello,</p>
                            <p>You have been invited to a meeting scheduled by your team lead.</p>
                            <div style="background: #f8fafc; padding: 20px; border-radius: 8px; margin: 20px 0;">
                                <h2 style="margin-top: 0; color: #6366f1;"><%= meetingTitle %></h2>
                                <p><strong><i class="bi bi-calendar"></i> Date & Time:</strong> <%= meetingDateTime %></p>
                                <p><strong><i class="bi bi-geo-alt"></i> Location/Link:</strong> <%= locals.locationText || '---' %></p>
                                <% if (locals.meetingLink) { %>
                                    <p><strong><i class="bi bi-link-45deg"></i> Join Link:</strong> <a href="<%= meetingLink %>"><%= meetingLink %></a></p>
                                <% } %>
                                <p>Please check your dashboard for further details and to join the meeting.</p>
                            </div>
                            <div style="text-align: center; margin-top: 30px;">
                                <a href="${window.location.origin}/dashboard" style="background: #6366f1; color: white; padding: 12px 25px; text-decoration: none; border-radius: 5px; font-weight: bold;">Go to Dashboard</a>
                            </div>
                        </div>
                        <div style="background: #f1f5f9; color: #64748b; padding: 15px; text-align: center; font-size: 12px;">
                            Nexus AI Management Console &copy; 2026
                        </div>
                    </div>
                `
            };

            try {
                const response = await fetch('/send_invite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                if (data.success) {
                    window.location.href = `/successmeetingcreate?title=<%= encodeURIComponent(meetingTitle) %>&datetime=<%= encodeURIComponent(meetingDateTime) %>&location=<%= encodeURIComponent(locals.locationText || '---') %>&inviteCount=${selectedUsers.size}`;
                } else {
                    alert('Error: ' + (data.error || 'Failed to send invitations'));
                    overlay.style.display = 'none';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Failed to connect to the invitation server.');
                overlay.style.display = 'none';
            }
        }
    </script>
<%- include('../utils/footer') %>
</main>
</body>
</html>
