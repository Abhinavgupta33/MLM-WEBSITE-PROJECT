<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NexusSphere | Elite Access Portal</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <style>
        :root {
            --primary: #3b82f6;
            --primary-glow: rgba(59, 130, 246, 0.5);
            --secondary: #a855f7;
            --secondary-glow: rgba(168, 85, 247, 0.5);
            --bg-dark: #050a15;
            --text-main: #eef2ff;
            --glass-bg: rgba(10, 18, 35, 0.65);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-shadow: rgba(0, 0, 0, 0.6);
            --transition-elite: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            cursor: default;
        }

        /* 1. Liquid Constellation Background */
        #constellationCanvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            opacity: 0.6;
        }

        .glow-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -2;
            background: 
                radial-gradient(circle at 20% 20%, rgba(59, 130, 246, 0.15), transparent 40%),
                radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.15), transparent 40%);
            filter: blur(50px);
        }

        /* 2. Glass-Shimmer Aurora */
        @keyframes auroraMove {
            0% { transform: translate(-10%, -10%) rotate(0deg); }
            50% { transform: translate(10%, 10%) rotate(5deg); }
            100% { transform: translate(-10%, -10%) rotate(0deg); }
        }
        .aurora {
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(from 0deg at 50% 50%, transparent, var(--primary-glow), transparent 30%, var(--secondary-glow), transparent 60%);
            opacity: 0.05;
            animation: auroraMove 20s linear infinite;
            pointer-events: none;
        }

        /* 3. Elite Auth Card */
        .auth-container {
            width: 100%;
            max-width: 440px;
            padding: 1.5rem;
            z-index: 100;
        }

        .auth-card {
            background: var(--glass-bg);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 3.5rem;
            box-shadow: 0 40px 100px var(--glass-shadow);
            transform-style: preserve-3d;
            perspective: 1200px;
            position: relative;
            overflow: hidden;
        }

        /* Glass Shimmer Swipe */
        .auth-card::after {
            content: '';
            position: absolute;
            top: -150%; left: -150%;
            width: 300%; height: 300%;
            background: linear-gradient(135deg, transparent, rgba(255,255,255,0.05) 50%, transparent);
            transform: rotate(45deg);
            animation: shimmer 8s infinite linear;
            pointer-events: none;
        }
        @keyframes shimmer {
            0% { transform: translate(-30%, -30%) rotate(45deg); }
            100% { transform: translate(30%, 30%) rotate(45deg); }
        }

        .header {
            text-align: center;
            margin-bottom: 3rem;
        }

        /* Magnetic Logo */
        .logo-wrap {
            display: inline-block;
            margin-bottom: 1.5rem;
            position: relative;
        }

        .logo-icon {
            font-size: 3.5rem;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            filter: drop-shadow(0 0 15px var(--primary-glow));
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #fff, #94a3b8);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }

        p { color: #64748b; font-size: 0.95rem; font-weight: 500; }

        /* Electric Form */
        .form-group { margin-bottom: 1.8rem; position: relative; }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i {
            position: absolute;
            left: 1.5rem;
            font-size: 1.1rem;
            color: #475569;
            transition: var(--transition-elite);
            z-index: 2;
        }

        input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 1.25rem 1.25rem 1.25rem 3.5rem;
            color: white;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 400;
            transition: var(--transition-elite);
            outline: none;
        }

        /* Electric Focus State */
        input:focus {
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--primary);
            box-shadow: 
                0 0 0 4px rgba(59, 130, 246, 0.1),
                0 0 30px rgba(59, 130, 246, 0.2);
        }
        input:focus + i { color: var(--primary); transform: scale(1.1); filter: drop-shadow(0 0 8px var(--primary-glow)); }

        /* Glow on Valid (Experimental) */
        input:valid:not(:placeholder-shown) { border-color: #10b981; }

        /* Magnetic Button */
        .btn-wrap { position: relative; width: 100%; }
        
        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            border-radius: 20px;
            padding: 1.2rem;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition-elite);
            margin-top: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
        }

        .btn-submit:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 20px 40px rgba(59, 130, 246, 0.5);
            filter: brightness(1.1);
        }

        .footer-links {
            text-align: center;
            margin-top: 3rem;
            font-size: 0.9rem;
            color: #64748b;
        }

        .footer-links a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 700;
            margin-left: 0.5rem;
            transition: var(--transition-elite);
            position: relative;
        }

        .footer-links a::after {
            content: '';
            position: absolute;
            bottom: -4px; left: 0;
            width: 0%; height: 2px;
            background: var(--primary);
            transition: width 0.3s ease;
        }
        .footer-links a:hover { color: white; text-shadow: 0 0 10px var(--primary-glow); }
        .footer-links a:hover::after { width: 100%; }

        /* Mobile Optimization */
        @media (max-width: 767px) {
            body { height: auto; min-height: 100vh; padding: 1.5rem 0; overflow-y: auto; }
            .auth-container { max-width: 100%; padding: 1rem; }
            .auth-card { padding: 2.5rem 1.5rem; border-radius: 28px; }
            h1 { font-size: 1.8rem; }
        }
        @media (max-width: 400px) {
            .auth-card { padding: 2rem 1.2rem; border-radius: 22px; }
            h1 { font-size: 1.5rem; }
            input { padding: 1rem 1rem 1rem 3rem; font-size: 0.9rem; }
            .btn-submit { padding: 1rem; font-size: 0.9rem; }
            .logo-icon { font-size: 2.5rem; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <!-- Liquid Background -->
    <canvas id="constellationCanvas"></canvas>
    <div class="glow-overlay"></div>
    <div class="aurora"></div>

    <div class="auth-container">
        <div class="auth-card" id="tiltCard">
            <div class="header">
                <div class="logo-wrap" id="magLogo">
                    <i class="fas fa-cube logo-icon"></i>
                </div>
                <h1>Resident Login</h1>
                <p>Welcome to the Elite Nexus Network</p>
            </div>

            <form action="/loginrout" method="post">
                <div class="form-group">
                    <div class="input-wrapper">
                        <i class="fas fa-fingerprint"></i>
                        <input type="email" name="email" placeholder="Email Address" required>
                    </div>
                </div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <i class="fas fa-key"></i>
                        <input type="password" name="pass" placeholder="Password" required>
                    </div>
                </div>

                <div class="btn-wrap">
                    <button type="submit" class="btn-submit" id="magBtn">
                        Sign In Portal <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </form>

            <div class="footer-links" id="magFooter">
                New to the Sphere? <a href="/signup_page">Apply for Residency</a>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /* 1. Liquid Constellation Background Engine */
            const canvas = document.getElementById('constellationCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouse = { x: null, y: null, radius: 150 };

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();

            window.addEventListener('mousemove', (e) => {
                mouse.x = e.x;
                mouse.y = e.y;
            });

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2 + 1;
                    this.baseX = this.x;
                    this.baseY = this.y;
                    this.density = (Math.random() * 30) + 1;
                }
                draw() {
                    ctx.fillStyle = 'rgba(238, 242, 255, 0.8)';
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.closePath();
                    ctx.fill();
                }
                update() {
                    let dx = mouse.x - this.x;
                    let dy = mouse.y - this.y;
                    let distance = Math.sqrt(dx * dx + dy * dy);
                    let forceDirectionX = dx / distance;
                    let forceDirectionY = dy / distance;
                    let maxDistance = mouse.radius;
                    let force = (maxDistance - distance) / maxDistance;
                    let directionX = forceDirectionX * force * this.density;
                    let directionY = forceDirectionY * force * this.density;

                    if (distance < mouse.radius) {
                        this.x -= directionX;
                        this.y -= directionY;
                    } else {
                        if (this.x !== this.baseX) {
                            let dx = this.x - this.baseX;
                            this.x -= dx / 10;
                        }
                        if (this.y !== this.baseY) {
                            let dy = this.y - this.baseY;
                            this.y -= dy / 10;
                        }
                    }
                }
            }

            function initParticles() {
                particles = [];
                for (let i = 0; i < 150; i++) {
                    particles.push(new Particle());
                }
            }
            initParticles();

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (let i = 0; i < particles.length; i++) {
                    particles[i].draw();
                    particles[i].update();
                }
                connect();
                requestAnimationFrame(animate);
            }

            function connect() {
                let opacityValue = 1;
                for (let a = 0; a < particles.length; a++) {
                    for (let b = a; b < particles.length; b++) {
                        let dx = particles[a].x - particles[b].x;
                        let dy = particles[a].y - particles[b].y;
                        let distance = Math.sqrt(dx * dx + dy * dy);
                        if (distance < 100) {
                            opacityValue = 1 - (distance / 100);
                            ctx.strokeStyle = `rgba(59, 130, 246, ${opacityValue * 0.2})`;
                            ctx.lineWidth = 1;
                            ctx.beginPath();
                            ctx.moveTo(particles[a].x, particles[a].y);
                            ctx.lineTo(particles[b].x, particles[b].y);
                            ctx.stroke();
                        }
                    }
                }
            }
            animate();

            /* 2. Magnetic Logic */
            const magElements = [
                { el: document.getElementById('magLogo'), strength: 0.4 },
                { el: document.getElementById('magBtn'), strength: 0.2 },
                { el: document.getElementById('magFooter'), strength: 0.1 }
            ];

            document.addEventListener('mousemove', (e) => {
                magElements.forEach(({el, strength}) => {
                    if (!el) return;
                    const rect = el.getBoundingClientRect();
                    const x = e.clientX - (rect.left + rect.width / 2);
                    const y = e.clientY - (rect.top + rect.height / 2);
                    const distance = Math.sqrt(x * x + y * y);

                    if (distance < 150) {
                        gsap.to(el, {
                            x: x * strength,
                            y: y * strength,
                            duration: 0.6,
                            ease: 'power2.out'
                        });
                    } else {
                        gsap.to(el, { x: 0, y: 0, duration: 1, ease: 'elastic.out(1, 0.3)' });
                    }
                });
            });

            /* 3. 3D Tilt */
            const card = document.getElementById('tiltCard');
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = (e.clientX - rect.left) / rect.width - 0.5;
                const y = (e.clientY - rect.top) / rect.height - 0.5;
                gsap.to(card, {
                    rotateX: -y * 12,
                    rotateY: x * 12,
                    duration: 0.5,
                    ease: 'power2.out',
                    transformPerspective: 1200
                });
            });
            card.addEventListener('mouseleave', () => {
                gsap.to(card, { rotateX: 0, rotateY: 0, duration: 1, ease: 'elastic.out(1, 0.3)' });
            });

            /* 4. Electric Input Icons */
            document.querySelectorAll('input').forEach(input => {
                input.addEventListener('mousemove', (e) => {
                    const icon = input.previousElementSibling;
                    if (!icon) return;
                    const rect = icon.getBoundingClientRect();
                    const x = e.clientX - (rect.left + rect.width/2);
                    const y = e.clientY - (rect.top + rect.height/2);
                    gsap.to(icon, { x: x * 0.3, y: y * 0.3, duration: 0.4 });
                });
                input.addEventListener('mouseleave', () => {
                    gsap.to(input.previousElementSibling, { x: 0, y: 0, duration: 0.6 });
                });
            });

            /* 5. Staggered Entrance */
            gsap.from('.auth-card', {
                y: 100,
                opacity: 0,
                duration: 1.5,
                ease: 'expo.out'
            });
            gsap.from('.auth-card > *', {
                y: 30,
                opacity: 0,
                duration: 1,
                stagger: 0.1,
                ease: 'power4.out',
                delay: 0.5
            });
        });
    </script>
</body>
</html>
