          align-items: flex-start;
        }
        
        .activity-icon {
          margin-right: 0;
          margin-bottom: 10px;
        }
        
        .leaderboard-item {
          flex-direction: column;
          align-items: flex-start;
        }
        
        .rank {
          margin-right: 0;
          margin-bottom: 10px;
        }
        
        .calendar-stats .stat-value {
