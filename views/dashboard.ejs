        }
        
        .calendar-stats .stat-label {
          font-size: 0.6rem;
        }
        
        .calendar-day {
          padding: 5px 2px;
          font-size: 0.8rem;
        }
        
        .calendar-day-header {
          font-size: 0.7rem;
        }
      }
      
      @media (max-width: 400px) {
        .pagetitle h1 {
          font-size: 1.3rem;
        }
        
        .dashboard-card h5 {
          font-size: 1rem;
        }
        
        .dashboard-card h2 {
          font-size: 1.5rem;
        }
        
        .quick-action-title {
