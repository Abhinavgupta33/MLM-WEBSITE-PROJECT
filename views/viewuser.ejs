<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <title>Tables / Data - NiceAdmin Bootstrap Template</title>
    <meta content="" name="description" />
    <meta content="" name="keywords" />
    <link href="../assets/img/favicon.png" rel="icon" />
    <link href="../assets/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <link href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Nunito:300,300i,400,400i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i"
      rel="stylesheet"
    />

    <link
      href="../assets/vendor/bootstrap/css/bootstrap.min.css"
      rel="stylesheet"
    />
   
    <style>
      #main {
        margin-left: var(--sidebar-width, 280px);
        padding-top: calc(var(--header-height, 80px) + 20px);
        transition: all 0.3s;
      }
      
      .pagetitle { padding-left: 20px; }
      
      .filter-container {
        margin: 0 15px;
      }

      /* Table horizontal scroll */
      .card[style*="overflow-x"] { overflow-x: auto !important; }
      table.table { min-width: 900px; }
      
      @media (max-width: 991px) {
        #main { margin-left: 0 !important; padding-top: calc(var(--header-height, 80px) + 15px); }
        .filter-container { margin: 0 10px; }
      }
      
      @media (max-width: 576px) {
        .pagetitle { padding-left: 10px; }
        .filter-container { margin: 0 5px; }
        .filter-container .col-md-4 { flex: 0 0 100%; max-width: 100%; margin-bottom: 10px; }
        table td, table th { font-size: 0.75rem; padding: 6px 4px; }
        .btn { font-size: 0.75rem; padding: 4px 6px; }
      }
    </style>

    <script
      src="https://code.jquery.com/jquery-3.7.1.js"
      integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4="
      crossorigin="anonymous"
    ></script>
  
    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

  <body>
    <%- include("../utils/header")%> 
    <%- include("side")%>

    <main id="main" class="main">
      <div class="pagetitle">
        <h1>Data Tables</h1>
        <nav>
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
            <li class="breadcrumb-item">Services</li>
          </ol>
        </nav>
      </div>
      <!-- End Page Title -->

      <div class="filter-container">
        <div class="card">
          <div class="card-header">
            <form
              class="row g-3 needs-validation"
              novalidate
              action="/filteruser"
              method="post"
            >
              <div class="col-md-4">
                <label for="validationCustom01" class="form-label">Name</label>
                <input type="text" class="form-control" id="validationCustom01"
                value=""
                name="filtername" placeholder="Search by Name">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label">Email</label>
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filteremail" placeholder="Search by Email">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label">UserId</label>
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filterId" placeholder="Search by UserId">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label"
                  >Mobile No</label
                >
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filtermobile" placeholder="Search by Mobile Number">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label"
                  >Brokrage</label
                >
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filterbrokrage" placeholder="Search by Brokrage">
                <div class="valid-feedback">Looks good!</div>
              </div>
              <div class="col-md-4">
                <label for="validationCustom02" class="form-label">Amounts</label>
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filterpoints" placeholder="Search by Points">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label">Margin</label>
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filtermargin" placeholder="Search by Margin">
                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-md-4">
                <label for="validationCustom02" class="form-label"
                  >Actual_Amt</label
                >
                <input type="text" class="form-control" id="validationCustom02"
                value=""
                name="filteractual_data_amount" placeholder="Search by User_Amt">

                <div class="valid-feedback">Looks good!</div>
              </div>

              <div class="col-12">
                <button class="btn btn-primary" type="submit">Submit form</button>
              </div>
            </form>
            <!-- End Custom Styled Validation -->
          </div>
        </div>
      </div>

      <section class="section">
        <div class="row">
          <div class="col-lg-12">
            <div class="card" style="overflow-x: scroll">
              <div class="card-body">
                <h5 class="card-title">Datatables</h5>
                <!-- Table with stripped rows -->
                <table class="table datatable">
                    <tbody>
                        <% users.forEach((user, index) => { %>
                          <tr>
                            <td><%= index + 1 %></td>
                            <td><%= user.name %></td>
                            <td><%= user.email %></td>
                            <td><%= user.user_id %></td>
                            <td><%= user.mobile %></td>
                            <td><%= user.brokrage %></td>
                            <td><%= user.amount %></td>
                            <td><%= user.actual_amount %></td>
                            <td><%= user.margin %></td>
                            <td>
                              <form class="filter" action="/user_block" method="post">
                                <input type="hidden" name="id" value="<%= user.user_id %>" />
                                <input type="hidden" name="access" value="<%= user.access %>" />
                                <% if (user.access === "unblock") { %>
                                  <input type="submit" class="btn btn-success" value="Unblock" />
                                <% } else { %>
                                  <input type="submit" class="btn btn-danger" value="Block" />
                                <% } %>
                              </form>
                            </td>
                            
                            <td>
                                <form class="filter" action="/user_unblock" method="post">
                                  <input type="hidden" name="id" value="<%= user.user_id %>" />
                                  <input type="submit" value="Unblock" class="btn btn-warning" />
                                </form>
                              </td>
                            <td>
                              <form class="filter" action="/user_mail" method="post">
                                <input type="hidden" name="email" value="<%= user.email %>" />
                                <input type="submit" value="Mail" class="btn btn-primary" />
                              </form>
                            </td>
                            <td>
                              <form class="filter" action="/user" method="post">
                                <input type="hidden" name="id" value="<%= user.user_id %>" />
                                <input type="submit" value="Update Profile" class="btn btn-info" />
                              </form>
                            </td>
                            <td>
                              <form
                                class="filter"
                                action="/delete_user"
                                method="post"
                                onsubmit="return confirmDelete();"
                              >
                                <input type="hidden" name="id" value="<%= user.user_id %>" />
                                <input type="submit" value="Delete User" class="btn btn-dark" />
                              </form>
                            </td>
                            <td>
                              <form class="filter" action="/viewprofile" method="post">
                                <input type="hidden" name="id" value="<%= user.email%>" />
                                <input type="submit" value="View Profile" class="btn btn-info" />
                              </form>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                </table>
                <!-- End Table with stripped rows -->
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <!-- End #main -->

    <%- include("../utils/footer")%>

    <a
      href="#"
      class="back-to-top d-flex align-items-center justify-content-center"
      ><i class="bi bi-arrow-up-short"></i
    ></a>
    <script>
      function confirmDelete() {
        return confirm("Are you sure you want to delete this user?");
      }
    </script>
    <!-- Vendor JS Files -->
    <script src="assets/vendor/apexcharts/apexcharts.min.js"></script>
    <script src="assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="assets/vendor/chart.js/chart.min.js"></script>
    <script src="assets/vendor/echarts/echarts.min.js"></script>
    <script src="assets/vendor/quill/quill.min.js"></script>
    <script src="assets/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="assets/vendor/tinymce/tinymce.min.js"></script>
    <script src="assets/vendor/php-email-form/validate.js"></script>

    <!-- Template Main JS File -->
    <script src="assets/js/main.js"></script>
  </body>
</html>