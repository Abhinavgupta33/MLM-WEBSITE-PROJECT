<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catalog Management | Antigravity</title>

    <link href="../assets/img/favicon.png" rel="icon" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="../assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="../assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #4361ee;
            --primary-glow: rgba(67, 97, 238, 0.3);
            --primary-dark: #3a0ca3;
            --success-color: #4cc9f0;
            --danger-color: #f72585;
            --warning-color: #f8961e;
            --card-bg: rgba(255, 255, 255, 0.85);
            --glass-border: rgba(255, 255, 255, 0.4);
            --body-bg: #f0f2f5;
            --text-color: #1e293b;
            --text-muted-color: #64748b;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body.dark-mode {
            --card-bg: rgba(30, 41, 59, 0.8);
            --glass-border: rgba(255, 255, 255, 0.07);
            --body-bg: #0f172a;
            --text-color: #f1f5f9;
            --text-muted-color: #94a3b8;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-color);
            background-image:
                radial-gradient(at 0% 0%, rgba(67, 97, 238, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(76, 201, 240, 0.08) 0px, transparent 50%);
            min-height: 100vh;
            transition: var(--transition);
        }

        /* ===================== */
        /* Main content wrapper  */
        /* ===================== */
        #main {
            padding-top: 30px;
            padding-bottom: 60px;
        }

        .admin-container {
            width: 100%;
            max-width: 1400px;
            padding: 0 40px;
            margin: 0 auto;
            animation: fadeSlideIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) backwards;
        }

        /* ===================== */
        /* Page Header            */
        /* ===================== */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .page-title {
            font-weight: 800;
            font-size: 2.2rem;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, var(--primary), var(--success-color), var(--danger-color));
            background-size: 300% 300%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradientShift 6s ease infinite;
            margin-bottom: 4px;
        }

        .page-subtitle {
            color: var(--text-muted-color);
            font-size: 0.95rem;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .btn-add-product {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 14px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            box-shadow: 0 6px 20px var(--primary-glow);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .btn-add-product:hover {
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 14px 30px var(--primary-glow);
            color: white;
        }

        /* ===================== */
        /* Stats Grid             */
        /* ===================== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 24px;
            margin-bottom: 36px;
        }

        .stat-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.25), transparent 70%);
            transform: translateX(-100%);
            transition: 0.7s ease;
        }

        .stat-card:hover { transform: translateY(-8px) scale(1.02); box-shadow: 0 20px 50px rgba(67, 97, 238, 0.15); border-color: rgba(67,97,238,0.3); }
        .stat-card:hover::before { transform: translateX(100%); }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: white;
            flex-shrink: 0;
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .stat-card:hover .stat-icon { transform: rotate(10deg) scale(1.12); }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
            color: var(--text-color);
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-muted-color);
            font-weight: 500;
            margin-top: 4px;
        }

        /* ===================== */
        /* Search Bar             */
        /* ===================== */
        .search-bar {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 2px solid var(--glass-border);
            border-radius: 16px;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 36px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .search-bar:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-glow);
            transform: scaleX(1.005);
        }

        .search-bar i { color: var(--text-muted-color); font-size: 1.1rem; flex-shrink: 0; }

        .search-bar input {
            background: transparent;
            border: none;
            color: var(--text-color);
            width: 100%;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            outline: none;
        }

        .search-bar input::placeholder { color: var(--text-muted-color); }

        /* ===================== */
        /* Product Grid           */
        /* ===================== */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        /* ===================== */
        /* Product Card           */
        /* ===================== */
        .product-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            position: relative;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            animation: fadeSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) backwards;
            box-shadow: 0 8px 30px rgba(0,0,0,0.05);
        }

        .product-card:hover {
            transform: translateY(-14px) scale(1.02);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
            border-color: rgba(67, 97, 238, 0.5);
        }

        /* Low stock badge */
        .badge-low-stock {
            position: absolute;
            top: 20px;
            right: 20px;
            background: linear-gradient(135deg, var(--danger-color), #ff4d6d);
            color: white;
            padding: 5px 14px;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            box-shadow: 0 4px 12px rgba(247, 37, 133, 0.4);
            animation: pulseBadge 2s infinite;
        }

        @keyframes pulseBadge {
            0%, 100% { box-shadow: 0 0 0 0 rgba(247, 37, 133, 0.5); }
            50% { box-shadow: 0 0 0 8px rgba(247, 37, 133, 0); }
        }

        /* Product image box */
        .product-img-box {
            height: 220px;
            border-radius: 18px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            margin-bottom: 20px;
            overflow: hidden;
            position: relative;
            transition: var(--transition);
            box-shadow: inset 0 2px 12px rgba(0,0,0,0.04);
        }

        body.dark-mode .product-img-box { background: rgba(255,255,255,0.06); }

        .product-img-box::after {
            content: '';
            position: absolute;
            inset: -50%;
            background: radial-gradient(circle, rgba(255,255,255,0.7) 0%, transparent 65%);
            opacity: 0;
            transition: opacity 0.5s;
            mix-blend-mode: overlay;
            pointer-events: none;
        }

        .product-card:hover .product-img-box::after { opacity: 1; }

        .product-img-box img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.5s ease;
            filter: drop-shadow(0 8px 16px rgba(0,0,0,0.1));
        }

        .product-card:hover .product-img-box img {
            transform: scale(1.18) translateY(-6px) rotate(2deg);
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.18));
        }

        /* Product info */
        .product-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-color);
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .product-category {
            font-size: 0.82rem;
            color: var(--text-muted-color);
            margin-bottom: 20px;
            font-weight: 500;
        }

        /* Editable price & quantity */
        .product-meta {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 20px;
            gap: 12px;
        }

        .meta-label {
            font-size: 0.72rem;
            color: var(--text-muted-color);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .editable-field {
            cursor: pointer;
            padding: 6px 10px;
            border-radius: 10px;
            background: rgba(67, 97, 238, 0.06);
            border: 1.5px solid transparent;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-weight: 700;
            font-size: 1rem;
        }

        .editable-field:hover {
            background: rgba(67, 97, 238, 0.14);
            border-color: var(--primary);
            transform: scale(1.03);
        }

        .edit-input {
            width: 90px;
            background: var(--body-bg);
            border: 2px solid var(--primary);
            border-radius: 8px;
            padding: 4px 10px;
            color: var(--text-color);
            font-size: 0.9rem;
            font-family: 'Inter', sans-serif;
            outline: none;
        }

        /* Action buttons */
        .card-actions {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            margin-top: auto;
        }

        .btn-edit {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 11px 16px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 13px;
            font-weight: 600;
            font-size: 0.88rem;
            text-decoration: none;
            box-shadow: 0 4px 14px var(--primary-glow);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .btn-edit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 24px var(--primary-glow);
            color: white;
        }

        .btn-delete {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            border-radius: 13px;
            background: transparent;
            border: 2px solid rgba(247, 37, 133, 0.3);
            color: var(--danger-color);
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .btn-delete:hover {
            background: var(--danger-color);
            border-color: var(--danger-color);
            color: white;
            transform: translateY(-3px) rotate(8deg);
            box-shadow: 0 10px 24px rgba(247, 37, 133, 0.4);
        }

        /* ===================== */
        /* Animations             */
        /* ===================== */
        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(40px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        /* ===================== */
        /* Responsive             */
        /* ===================== */
        @media (max-width: 992px) {
            .admin-container { padding: 0 20px; }
            .page-title { font-size: 1.6rem; }
        }

        @media (max-width: 576px) {
            .product-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <%- include("../utils/header") %>
    <%- include("side") %>

    <main id="main">
        <div class="admin-container">

            <!-- Page Header -->
            <div class="page-header">
                <div>
                    <h1 class="page-title">Catalog Management</h1>
                    <p class="page-subtitle">Manage your product inventory and pricing</p>
                </div>
                <a href="/addproduct" class="btn-add-product">
                    <i class="bi bi-plus-lg"></i> Add Product
                </a>
            </div>

            <%
                const total = products.length;
                const low = products.filter(p => p.product_quantity <= 10 && p.product_quantity > 0).length;
                const out = products.filter(p => p.product_quantity === 0).length;
            %>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card" style="animation-delay: 0.05s">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #4361ee, #4cc9f0);">
                        <i class="bi bi-collection"></i>
                    </div>
                    <div>
                        <div class="stat-value"><%= total %></div>
                        <div class="stat-label">Active Products</div>
                    </div>
                </div>
                <div class="stat-card" style="animation-delay: 0.15s">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #f8961e, #f9c74f);">
                        <i class="bi bi-graph-down-arrow"></i>
                    </div>
                    <div>
                        <div class="stat-value"><%= low %></div>
                        <div class="stat-label">Low Stock Alerts</div>
                    </div>
                </div>
                <div class="stat-card" style="animation-delay: 0.25s">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #f72585, #ff4d6d);">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div>
                        <div class="stat-value"><%= out %></div>
                        <div class="stat-label">Out of Stock</div>
                    </div>
                </div>
            </div>

            <!-- Search -->
            <div class="search-bar">
                <i class="bi bi-search"></i>
                <input type="text" id="catalogSearch" placeholder="Search products by name or category..." oninput="filterCatalog()">
            </div>

            <!-- Product Grid -->
            <div class="product-grid" id="productGrid">
                <% products.forEach((product, i) => { %>
                    <div class="product-card" style="animation-delay: <%= i * 0.04 %>s" data-name="<%= product.product_name.toLowerCase() %>">

                        <% if (product.product_quantity <= 10) { %>
                            <div class="badge-low-stock">
                                <%= product.product_quantity === 0 ? 'OUT OF STOCK' : 'LOW STOCK' %>
                            </div>
                        <% } %>

                        <div class="product-img-box">
                            <img src="<%= product.product_image %>" alt="<%= product.product_name %>">
                        </div>

                        <div class="product-name" title="<%= product.product_name %>">
                            <%= product.product_name %>
                        </div>
                        <div class="product-category">
                            <i class="bi bi-tag me-1"></i><%= product.product_category || 'General' %>
                        </div>

                        <div class="product-meta">
                            <div>
                                <div class="meta-label">Price</div>
                                <div class="editable-field text-primary"
                                    onclick="startQuickEdit(this, '<%= product._id %>', 'product_price', '<%= product.product_price %>')">
                                    <i class="bi bi-currency-rupee" style="font-size:0.85rem"></i>
                                    <%= product.product_price.toFixed(2) %>
                                    <i class="bi bi-pencil-fill" style="font-size:0.65rem; opacity:0.5"></i>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="meta-label">Inventory</div>
                                <div class="editable-field <%= product.product_quantity <= 10 ? 'text-danger' : 'text-success' %>"
                                    onclick="startQuickEdit(this, '<%= product._id %>', 'product_quantity', '<%= product.product_quantity %>')">
                                    <%= product.product_quantity %> Units
                                    <i class="bi bi-pencil-fill" style="font-size:0.65rem; opacity:0.5"></i>
                                </div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a href="/productedit/?productno=<%= product.product_no %>" class="btn-edit">
                                <i class="bi bi-pencil-square"></i> Edit Details
                            </a>
                            <button class="btn-delete" onclick="confirmDelete('<%= product.product_no %>', this.dataset.name)" data-name="<%= product.product_name %>">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>

                    </div>
                <% }) %>
            </div>

        </div>
    </main>

    <%- include('../utils/footer') %>

    <script>
        function filterCatalog() {
            const query = document.getElementById('catalogSearch').value.toLowerCase();
            document.querySelectorAll('.product-card').forEach(card => {
                card.style.display = card.dataset.name.includes(query) ? 'flex' : 'none';
            });
        }

        let isEditing = false;
        function startQuickEdit(element, productId, field, currentVal) {
            if (isEditing) return;
            isEditing = true;

            const input = document.createElement('input');
            input.type = 'number';
            input.className = 'edit-input';
            input.value = parseFloat(currentVal);
            input.min = 0;

            const originalHtml = element.innerHTML;
            element.innerHTML = '';
            element.appendChild(input);
            input.focus();

            const finish = () => finishEdit(element, productId, field, input.value, originalHtml);
            input.onblur = finish;
            input.onkeydown = (e) => {
                if (e.key === 'Enter') finish();
                if (e.key === 'Escape') { element.innerHTML = originalHtml; isEditing = false; }
            };
        }

        async function finishEdit(element, productId, field, newVal, originalHtml) {
            if (!isEditing) return;
            try {
                const response = await fetch('/quickupdate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, field, value: newVal })
                });
                const data = await response.json();
                if (data.success) {
                    const editIcon = '<i class="bi bi-pencil-fill" style="font-size:0.65rem; opacity:0.5"></i>';
                    if (field === 'product_price') {
                        element.innerHTML = `<i class="bi bi-currency-rupee" style="font-size:0.85rem"></i>${parseFloat(newVal).toFixed(2)} ${editIcon}`;
                    } else {
                        element.innerHTML = `${newVal} Units ${editIcon}`;
                        element.classList.toggle('text-danger', parseFloat(newVal) <= 10);
                        element.classList.toggle('text-success', parseFloat(newVal) > 10);
                    }
                } else {
                    element.innerHTML = originalHtml;
                }
            } catch (err) {
                element.innerHTML = originalHtml;
            } finally {
                isEditing = false;
            }
        }

        function confirmDelete(id, name) {
            if (confirm(`Are you sure you want to delete "${name}"?\nThis action cannot be undone.`)) {
                window.location.href = `/productdelete?productno=${id}`;
            }
        }
    </script>
</body>
</html>
