<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexusSphere | Identity Verified | Welcome Aboard</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <style>
        :root {
            --primary: #10b981;
            --primary-glow: rgba(16, 185, 129, 0.4);
            --bg-dark: #050a15;
            --text-main: #eef2ff;
            --glass-bg: rgba(10, 15, 12, 0.85);
            --glass-border: rgba(16, 185, 129, 0.2);
            --glass-shadow: rgba(0, 0, 0, 0.8);
            --transition-elite: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        #constellationCanvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.5;
        }
        .glow-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
            background: radial-gradient(circle at 50% 50%, rgba(16, 185, 129, 0.1), transparent 60%);
            filter: blur(80px);
        }

        .container { width: 100%; max-width: 520px; padding: 1.5rem; z-index: 100; }

        .success-card {
            background: var(--glass-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 4rem 3rem;
            box-shadow: 0 40px 100px var(--glass-shadow);
            transform-style: preserve-3d;
            perspective: 1200px;
            position: relative;
            text-align: center;
        }

        .icon-wrap { margin-bottom: 2rem; position: relative; }
        .check-icon {
            font-size: 5.5rem;
            background: linear-gradient(135deg, var(--primary), #059669);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            filter: drop-shadow(0 0 25px var(--primary-glow));
        }

        h1 {
            font-size: 2.2rem; font-weight: 800; letter-spacing: -1px;
            background: linear-gradient(135deg, #fff, #a7f3d0);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin-bottom: 1.2rem;
        }
        p { color: #94a3b8; font-size: 1rem; line-height: 1.7; margin-bottom: 2.5rem; }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, var(--primary), #065f46);
            color: white; border: none; border-radius: 20px; padding: 1.3rem;
            font-size: 1.1rem; font-weight: 700; cursor: pointer;
            transition: var(--transition-elite);
            display: flex; align-items: center; justify-content: center; gap: 1rem;
            text-decoration: none;
            box-shadow: 0 15px 35px var(--primary-glow);
            text-transform: uppercase; letter-spacing: 2px;
        }
        .btn-login:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 50px rgba(16, 185, 129, 0.6);
            filter: brightness(1.1);
        }

        .countdown-bar {
            margin-top: 2rem; color: #4b5563; font-size: 0.9rem; font-weight: 600;
        }
        #seconds { color: var(--primary); font-weight: 800; }

        .confetti-piece {
            position: absolute; width: 8px; height: 8px; background: var(--primary);
            border-radius: 2px; opacity: 0; z-index: -1;
        }
        @media (max-width: 767px) {
            body { height: auto; min-height: 100vh; overflow-y: auto; padding: 1.5rem 0; }
            .container { max-width: 100%; padding: 1rem; }
            .success-card { border-radius: 28px; }
        }
        @media (max-width: 480px) {
            .success-card { padding: 2.5rem 1.2rem; border-radius: 22px; }
            h1 { font-size: 1.6rem; }
            .check-icon { font-size: 3.5rem; }
            .btn-login { font-size: 1rem; padding: 1rem; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <canvas id="constellationCanvas"></canvas>
    <div class="glow-overlay"></div>

    <div class="container">
        <div class="success-card" id="tiltCard">
            <div class="icon-wrap" id="magIcon">
                <i class="fas fa-check-circle check-icon"></i>
            </div>
            <h1>Registry Complete</h1>
            <p>Welcome to NexusSphere Elite. Your identity has been successfully encrypted and broadcast to the network.</p>

            <a href="/" class="btn-login" id="loginBtn">
                <i class="fas fa-portal-enter"></i> Enter Portal
            </a>

            <div class="countdown-bar">
                Neural bypass active. Automatic redirection in <span id="seconds">10</span> seconds...
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('constellationCanvas');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let mouse = { x: null, y: null, radius: 150 };
            function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
            window.addEventListener('resize', resize); resize();
            window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2 + 1; this.baseX = this.x; this.baseY = this.y;
                    this.density = (Math.random() * 30) + 1;
                }
                draw() { ctx.fillStyle = 'rgba(16, 185, 129, 0.4)'; ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill(); }
                update() {
                    let dx = mouse.x - this.x; let dy = mouse.y - this.y;
                    let dist = Math.sqrt(dx*dx + dy*dy);
                    if (dist < mouse.radius) {
                        let force = (mouse.radius - dist) / mouse.radius;
                        this.x -= (dx/dist) * force * this.density;
                        this.y -= (dy/dist) * force * this.density;
                    } else {
                        this.x -= (this.x - this.baseX) / 10; this.y -= (this.y - this.baseY) / 10;
                    }
                }
            }
            function init() { for(let i=0; i<80; i++) particles.push(new Particle()); }
            function animate() {
                ctx.clearRect(0,0,canvas.width,canvas.height);
                particles.forEach(p => { p.draw(); p.update(); });
                connect(); requestAnimationFrame(animate);
            }
            function connect() {
                for(let a=0; a<particles.length; a++) {
                    for(let b=a; b<particles.length; b++) {
                        let dist = Math.sqrt(Math.pow(particles[a].x - particles[b].x, 2) + Math.pow(particles[a].y - particles[b].y, 2));
                        if(dist < 120) {
                            ctx.strokeStyle = `rgba(16,185,129,${(1 - dist/120) * 0.1})`;
                            ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(particles[a].x, particles[a].y); ctx.lineTo(particles[b].x, particles[b].y); ctx.stroke();
                        }
                    }
                }
            }
            init(); animate();

            const card = document.getElementById('tiltCard');
            card.addEventListener('mousemove', (e) => {
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left)/r.width - 0.5;
                const y = (e.clientY - r.top)/r.height - 0.5;
                gsap.to(card, { rotateX: -y * 10, rotateY: x * 10, duration: 0.5 });
            });
            card.addEventListener('mouseleave', () => gsap.to(card, { rotateX: 0, rotateY: 0, duration: 1, ease: 'elastic.out' }));

            const targets = [
                { el: document.getElementById('magIcon'), s: 0.3 },
                { el: document.getElementById('loginBtn'), s: 0.15 }
            ];
            document.addEventListener('mousemove', (e) => {
                targets.forEach(t => {
                    const r = t.el.getBoundingClientRect();
                    const dx = e.clientX - (r.left + r.width/2);
                    const dy = e.clientY - (r.top + r.height/2);
                    if(Math.sqrt(dx*dx + dy*dy) < 150) {
                        gsap.to(t.el, { x: dx*t.s, y: dy*t.s, duration: 0.6 });
                    } else { gsap.to(t.el, { x: 0, y: 0, duration: 1 }); }
                });
            });

            // Countdown Logic
            let secondsLeft = 10;
            const secSpan = document.getElementById('seconds');
            const timer = setInterval(() => {
                secondsLeft--;
                secSpan.innerText = secondsLeft;
                if(secondsLeft <= 0) {
                    clearInterval(timer);
                    window.location.href = '/';
                }
            }, 1000);

            // Celebration Confetti
            for(let i=0; i<30; i++) {
                const p = document.createElement('div');
                p.className = 'confetti-piece';
                document.body.appendChild(p);
                gsap.set(p, { x: window.innerWidth/2, y: window.innerHeight/2, scale: Math.random() });
                gsap.to(p, {
                    x: Math.random() * window.innerWidth,
                    y: Math.random() * window.innerHeight,
                    opacity: 1, duration: 2, ease: 'power4.out',
                    rotation: Math.random() * 360,
                    delay: 0.2
                });
                gsap.to(p, { y: '+=100', opacity: 0, duration: 3, delay: 2 });
            }

            gsap.from(card, { scale: 0.5, opacity: 0, duration: 1.5, ease: 'expo.out' });
        });
    </script>
</body>
</html>
