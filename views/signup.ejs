<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NexusSphere | Identity Verification | Elite Residency</title>

    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <style>
        :root {
            --primary: #3b82f6;
            --primary-glow: rgba(59, 130, 246, 0.5);
            --secondary: #a855f7;
            --secondary-glow: rgba(168, 85, 247, 0.5);
            --bg-dark: #050a15;
            --text-main: #eef2ff;
            --glass-bg: rgba(10, 18, 35, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: rgba(0, 0, 0, 0.5);
            --transition-elite: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            --error: #ef4444;
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 2.5rem 1rem;
            cursor: default;
        }

        /* 1. Liquid Background Engine */
        #constellationCanvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            opacity: 0.5;
        }
        .glow-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -2;
            background: 
                radial-gradient(circle at 10% 10%, rgba(59, 130, 246, 0.15), transparent 50%),
                radial-gradient(circle at 90% 90%, rgba(168, 85, 247, 0.15), transparent 50%);
            filter: blur(60px);
        }

        /* 2. Elite Registration Wrapper */
        .register-container {
            width: 100%;
            max-width: 960px;
            z-index: 100;
        }

        .hero-section { text-align: center; margin-bottom: 2.5rem; }
        .hero-section h1 { 
            font-size: 2.8rem; font-weight: 800; letter-spacing: -1.5px;
            background: linear-gradient(135deg, white, #94a3b8);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin-bottom: 0.5rem;
        }
        .hero-section p { color: #64748b; font-size: 1.1rem; font-weight: 500; }

        .register-card {
            background: var(--glass-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            box-shadow: 0 40px 100px var(--glass-shadow);
            transform-style: preserve-3d;
            perspective: 1200px;
            overflow: hidden;
            position: relative;
        }

        /* Glass Shimmer swipe */
        .register-card::before {
            content: ''; position: absolute; top: -150%; left: -150%; width: 300%; height: 300%;
            background: linear-gradient(135deg, transparent, rgba(255,255,255,0.03) 50%, transparent);
            transform: rotate(45deg); animation: shimmer 12s infinite linear; pointer-events: none;
        }
        @keyframes shimmer { 0% { transform: translate(-30%, -30%) rotate(45deg); } 100% { transform: translate(30%, 30%) rotate(45deg); } }

        /* Stepper Indicators */
        .steps-nav {
            padding: 2.5rem;
            background: rgba(255, 255, 255, 0.02);
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--glass-border);
        }
        .step-item {
            display: flex; align-items: center; gap: 1rem;
            opacity: 0.3; transition: var(--transition-elite);
            font-weight: 600; font-size: 0.9rem; letter-spacing: 0.5px;
        }
        .step-item.active { opacity: 1; color: var(--primary); }
        .step-item.completed { opacity: 0.7; color: var(--success); }

        .step-id {
            width: 38px; height: 38px;
            border: 2px solid currentColor;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 1rem;
            transition: var(--transition-elite);
        }
        .step-item.active .step-id { background: var(--primary); border-color: var(--primary); color: white; box-shadow: 0 0 20px var(--primary-glow); transform: scale(1.1); }
        .step-item.completed .step-id { background: var(--success); border-color: var(--success); color: white; }

        .step-divider { flex: 1; height: 1px; background: rgba(255, 255, 255, 0.05); margin: 0 1.5rem; position: relative; }
        .step-divider-fill { position: absolute; height: 100%; top: 0; left: 0; width: 0%; background: var(--primary); transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

        /* Form Logic */
        .form-content { padding: 4rem; position: relative; }
        .form-step { display: none; transform-origin: top center; }
        .form-step.active-step { display: block; }

        .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
        .full-width { grid-column: span 2; }

        .form-group { margin-bottom: 0.5rem; }
        .form-group label { display: block; margin-bottom: 0.75rem; font-size: 0.85rem; color: #475569; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
        
        .input-wrapper { position: relative; display: flex; align-items: center; }
        .input-wrapper i { position: absolute; left: 1.5rem; color: #475569; font-size: 1.1rem; transition: var(--transition-elite); z-index: 2; }

        input, select, textarea {
            width: 100%; background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px; padding: 1.25rem 1.25rem 1.25rem 3.5rem;
            color: white; font-family: inherit; font-size: 1rem; transition: var(--transition-elite); outline: none;
        }
        input:focus { border-color: var(--primary); background: rgba(255, 255, 255, 0.05); box-shadow: 0 0 30px rgba(59, 130, 246, 0.15); }
        input:focus + i { color: var(--primary); transform: scale(1.1); filter: drop-shadow(0 0 8px var(--primary-glow)); }

        .error-line { height: 2px; width: 0%; background: var(--error); position: absolute; bottom: 0; left: 0; transition: width 0.3s; }
        .input-wrapper.error .error-line { width: 100%; }

        /* Password Strength */
        .pw-strength-container { margin-top: 1rem; }
        .pw-bars { display: flex; gap: 5px; height: 4px; border-radius: 2px; overflow: hidden; }
        .pw-bar { flex: 1; background: rgba(255,255,255,0.05); transition: background 0.3s; }
        .pw-label { font-size: 0.7rem; font-weight: 700; color: #475569; margin-top: 5px; text-transform: uppercase; }

        /* File Upload Elite */
        .drop-zone {
            border: 2px dashed rgba(255,255,255,0.1); border-radius: 20px; padding: 3rem;
            text-align: center; cursor: pointer; transition: var(--transition-elite);
            background: rgba(255,255,255,0.01);
        }
        .drop-zone:hover { border-color: var(--primary); background: rgba(59, 130, 246, 0.03); transform: scale(0.99); }
        .drop-zone i { font-size: 2.5rem; color: var(--primary); margin-bottom: 1rem; filter: drop-shadow(0 0 10px var(--primary-glow)); }

        /* Tier Selection Cards */
        .tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem; }
        .tier-card {
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);
            border-radius: 25px; padding: 2rem 1.5rem; text-align: center; cursor: pointer; transition: var(--transition-elite);
            transform-style: preserve-3d;
        }
        .tier-card.selected { border-color: var(--primary); background: rgba(59, 130, 246, 0.08); transform: scale(1.05) translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
        .tier-card i { font-size: 2rem; margin-bottom: 1rem; color: var(--primary); }
        .tier-card h4 { font-size: 1.2rem; margin-bottom: 0.5rem; }
        .tier-card .price { font-size: 1.5rem; font-weight: 800; color: white; }

        /* Buttons Elite */
        .card-actions { display: flex; justify-content: space-between; gap: 1.5rem; margin-top: 3.5rem; }
        .btn {
            padding: 1.25rem 2.8rem; border-radius: 20px; font-weight: 700; font-family: inherit; font-size: 0.95rem;
            cursor: pointer; transition: var(--transition-elite); display: flex; align-items: center; gap: 0.8rem;
            letter-spacing: 1px;
        }
        .btn-mag { background: linear-gradient(135deg, var(--primary), var(--secondary)); border: none; color: white; box-shadow: 0 10px 30px rgba(59,130,246,0.3); }
        .btn-mag:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(59,130,246,0.5); }
        .btn-outline { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); color: white; }
        .btn-outline:hover { background: rgba(255,255,255,0.05); border-color: white; }

        .login-cta { text-align: center; margin-top: 2.5rem; font-size: 0.95rem; color: #64748b; font-weight: 500; }
        .login-cta a { color: var(--primary); text-decoration: none; font-weight: 800; margin-left: 0.5rem; transition: 0.3s; }
        .login-cta a:hover { color: white; text-shadow: 0 0 10px var(--primary-glow); }

        /* Modal Elite */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(15px);
            display: none; align-items: center; justify-content: center; z-index: 1000;
        }
        .modal-card {
            background: var(--glass-bg); border-radius: 40px; border: 1px solid var(--glass-border); padding: 4rem;
            text-align: center; max-width: 500px;
        }
        .modal-card i { font-size: 5rem; color: var(--success); margin-bottom: 2rem; filter: drop-shadow(0 0 20px rgba(16, 185, 129, 0.4)); }

        @media (max-width: 768px) {
            .form-grid, .tier-grid { grid-template-columns: 1fr; }
            .steps-nav { flex-direction: column; gap: 1.5rem; padding: 2rem; }
            .step-divider { display: none; }
            .register-container { max-width: 100%; padding: 0 0.5rem; }
            .hero-section h1 { font-size: 2rem; }
            .register-card { border-radius: 28px; }
        }
        @media (max-width: 480px) {
            body { padding: 1rem 0.5rem; }
            .hero-section h1 { font-size: 1.6rem; }
            .hero-section p { font-size: 0.9rem; }
            .form-content { padding: 1.5rem 1.2rem; }
            .steps-nav { padding: 1.5rem 1rem; gap: 1rem; }
            .modal-card { max-width: 100%; padding: 2.5rem 1.5rem; border-radius: 28px; margin: 0 1rem; }
            .btn { font-size: 0.9rem; padding: 1rem; }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3b82f6">
    <link rel="apple-touch-icon" href="/logo/site_logo.png">
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(reg => console.log('Service Worker registered', reg))
            .catch(err => console.log('Service Worker registration failed', err));
        });
      }
    </script>
</head>

<body>
    <canvas id="constellationCanvas"></canvas>
    <div class="glow-overlay"></div>

    <div class="register-container">
        <div class="hero-section">
            <h1 id="magTitle">Nexus <span style="background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; background-clip: text; color: transparent;">Sphere</span></h1>
            <p>Initiate your elite residency protocol.</p>
        </div>

        <div class="register-card" id="tiltCard">
            <!-- Navigation -->
            <div class="steps-nav">
                <div class="step-item active" data-step="1">
                    <div class="step-id">01</div>
                    <span>Persona</span>
                </div>
                <div class="step-divider"><div class="step-divider-fill" id="fill1"></div></div>
                <div class="step-item" data-step="2">
                    <div class="step-id">02</div>
                    <span>Identity</span>
                </div>
                <div class="step-divider"><div class="step-divider-fill" id="fill2"></div></div>
                <div class="step-item" data-step="3">
                    <div class="step-id">03</div>
                    <span>Tier</span>
                </div>
            </div>

            <div class="form-content">
                <form id="eliteForm">
                    <!-- Step 1 -->
                    <div class="form-step active-step" data-step="1">
                        <div class="form-grid">
                            <div class="form-group full-width">
                                <label>Legal Full Name</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-user-shield"></i>
                                    <input type="text" id="fullName" placeholder="Ex: Alexander Nexus" required>
                                    <div class="error-line"></div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Secured Line (Mobile)</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-phone-alt"></i>
                                    <input type="tel" id="mobile" placeholder="+1 (000) 000-0000" required>
                                    <div class="error-line"></div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Birth Date</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar-day"></i>
                                    <input type="date" id="dob" required>
                                    <div class="error-line"></div>
                                </div>
                            </div>
                            <div class="form-group full-width">
                                <label>Elite Communication (Email)</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-satellite-dish"></i>
                                    <input type="email" id="email" placeholder="resident@sphere.com" required>
                                    <div class="error-line"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-actions">
                            <div style="flex:1"></div>
                            <button type="button" class="btn btn-mag next-btn" data-target="2">Next Protocol <i class="fas fa-arrow-right"></i></button>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="form-step" data-step="2">
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Resident ID (Username)</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-id-badge"></i>
                                    <input type="text" id="username" placeholder="nexus_res_01" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Referral Matrix Code</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-code-branch"></i>
                                    <input type="text" id="referral" placeholder="NXS-ROOT-0">
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Master Key (Password)</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-lock"></i>
                                    <input type="password" id="password" placeholder="••••••••" required>
                                </div>
                                <div class="pw-strength-container">
                                    <div class="pw-bars"><div class="pw-bar" id="b1"></div><div class="pw-bar" id="b2"></div><div class="pw-bar" id="b3"></div><div class="pw-bar" id="b4"></div></div>
                                    <p class="pw-label" id="pwText">Strength: Null</p>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Confirm Master Key</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-shield-check"></i>
                                    <input type="password" id="confirmPassword" placeholder="••••••••" required>
                                </div>
                            </div>
                            <div class="form-group full-width">
                                <label>Biometric Profile (Photo)</label>
                                <div class="drop-zone" id="dropZone">
                                    <i class="fas fa-portrait"></i>
                                    <h4>Profile Identity Upload</h4>
                                    <p>Click to capture or drag-n-drop residency portrait</p>
                                    <input type="file" id="profileImg" accept="image/*" style="display: none;">
                                    <div id="fileInfo" style="margin-top: 1rem; color: var(--success); font-weight: 700; display: none;"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-actions">
                            <button type="button" class="btn btn-outline prev-btn" data-target="1"><i class="fas fa-chevron-left"></i> Previous</button>
                            <button type="button" class="btn btn-mag next-btn" data-target="3">Final Step <i class="fas fa-chevron-right"></i></button>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="form-step" data-step="3">
                        <h4 style="margin-bottom: 2rem; text-align: center; color: var(--primary); letter-spacing: 2px;">SELECT YOUR MEMBERSHIP LEVEL</h4>
                        <div class="tier-grid">
                            <div class="tier-card" data-tier="Basic" data-val="0">
                                <i class="fas fa-paper-plane"></i>
                                <h4>Initiate</h4>
                                <p class="price">$0</p>
                            </div>
                            <div class="tier-card selected" data-tier="Premium" data-val="99">
                                <i class="fas fa-gem"></i>
                                <h4>Resident</h4>
                                <p class="price">$99</p>
                            </div>
                            <div class="tier-card" data-tier="Elite" data-val="499">
                                <i class="fas fa-crown"></i>
                                <h4>Founder</h4>
                                <p class="price">$499</p>
                            </div>
                        </div>
                        <div class="form-group full-width" style="display:flex; gap:1.5rem; background: rgba(255,255,255,0.02); padding: 2rem; border-radius: 20px; border: 1px solid var(--glass-border);">
                            <input type="checkbox" id="terms" style="width: 25px; height: 25px; cursor: pointer; flex-shrink: 0;">
                            <p style="font-size: 0.85rem; line-height: 1.6;">I certify my commitment to the NexusSphere Protocol and agree to the decentralized dividend distribution policy outlined in the Sphere Charter.</p>
                        </div>
                        <div class="card-actions">
                            <button type="button" class="btn btn-outline prev-btn" data-target="2"><i class="fas fa-chevron-left"></i> Previous</button>
                            <button type="submit" class="btn btn-mag" id="finalizeBtn">Finalize Protocols <i class="fas fa-check-double"></i></button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="login-cta">
            Identity already matched? <a href="/login">Return to Terminal</a>
        </div>
    </div>

    <!-- Success Modal -->
    <div class="modal-overlay" id="successModal">
        <div class="modal-card">
            <i class="fas fa-check-circle"></i>
            <h2>Residency Confirmed</h2>
            <p>Your protocols have been verified. Welcome to the NexusSphere. Your access keys have been generated.</p>
            <button class="btn btn-mag" style="margin: 2.5rem auto 0;" onclick="window.location.href='/login'">Enter Terminal</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
             /* 1. Liquid Background Engine */
             const canvas = document.getElementById('constellationCanvas');
             const ctx = canvas.getContext('2d');
             let particles = [];
             let mouse = { x: null, y: null, radius: 150 };
             function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
             window.addEventListener('resize', resize); resize();
             window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });

             class Particle {
                 constructor() {
                     this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                     this.size = Math.random() * 2 + 1; this.baseX = this.x; this.baseY = this.y;
                     this.density = (Math.random() * 30) + 1;
                 }
                 draw() {
                     ctx.fillStyle = 'rgba(238, 242, 255, 0.6)'; ctx.beginPath();
                     ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
                 }
                 update() {
                     let dx = mouse.x - this.x; let dy = mouse.y - this.y;
                     let distance = Math.sqrt(dx * dx + dy * dy);
                     if (distance < mouse.radius) {
                         let force = (mouse.radius - distance) / mouse.radius;
                         this.x -= (dx / distance) * force * this.density;
                         this.y -= (dy / distance) * force * this.density;
                     } else {
                         this.x -= (this.x - this.baseX) / 10;
                         this.y -= (this.y - this.baseY) / 10;
                     }
                 }
             }
             function init() { particles = []; for(let i=0; i<150; i++) particles.push(new Particle()); }
             function animate() {
                 ctx.clearRect(0,0,canvas.width,canvas.height);
                 particles.forEach(p => { p.draw(); p.update(); });
                 connect(); requestAnimationFrame(animate);
             }
             function connect() {
                 for(let a=0; a<particles.length; a++) {
                     for(let b=a; b<particles.length; b++) {
                         let dx = particles[a].x - particles[b].x;
                         let dy = particles[a].y - particles[b].y;
                         let dist = Math.sqrt(dx*dx + dy*dy);
                         if(dist < 100) {
                             ctx.strokeStyle = `rgba(59,130,246,${(1 - dist/100) * 0.15})`;
                             ctx.lineWidth = 1; ctx.beginPath();
                             ctx.moveTo(particles[a].x, particles[a].y);
                             ctx.lineTo(particles[b].x, particles[b].y); ctx.stroke();
                         }
                     }
                 }
             }
             init(); animate();

             /* 2. Multi-Step Morphing Engine */
             let currentStep = 1;
             const form = document.querySelector('.register-card');
             const steps = document.querySelectorAll('.form-step');
             const indicators = document.querySelectorAll('.step-item');
             const fills = [document.getElementById('fill1'), document.getElementById('fill2')];

             function switchStep(next) {
                 const currentEl = document.querySelector(`.form-step[data-step="${currentStep}"]`);
                 const nextEl = document.querySelector(`.form-step[data-step="${next}"]`);
                 
                 // GSAP Timeline for Elite Transitions
                 const tl = gsap.timeline();
                 tl.to(currentEl, { opacity: 0, scale: 0.95, y: -20, duration: 0.5, ease: "power4.in", onComplete: () => currentEl.classList.remove('active-step') });
                 tl.fromTo(nextEl, { opacity: 0, scale: 1.05, y: 20 }, { 
                     opacity: 1, scale: 1, y: 0, duration: 0.8, ease: "expo.out", 
                     onStart: () => {
                         nextEl.classList.add('active-step');
                         currentStep = next;
                         updateIndicators();
                     }
                 }, "-=0.2");
             }

             function updateIndicators() {
                 indicators.forEach((ind, i) => {
                     ind.classList.toggle('active', i+1 === currentStep);
                     ind.classList.toggle('completed', i+1 < currentStep);
                 });
                 if(fills[0]) fills[0].style.width = currentStep > 1 ? '100%' : '0%';
                 if(fills[1]) fills[1].style.width = currentStep > 2 ? '100%' : '0%';
             }

             document.querySelectorAll('.next-btn').forEach(btn => btn.addEventListener('click', () => {
                 if(validateStep(currentStep)) switchStep(parseInt(btn.dataset.target));
             }));
             document.querySelectorAll('.prev-btn').forEach(btn => btn.addEventListener('click', () => switchStep(parseInt(btn.dataset.target))));

             function validateStep(s) {
                const div = document.querySelector(`.form-step[data-step="${s}"]`);
                const req = div.querySelectorAll('input[required]');
                let valid = true;
                req.forEach(i => {
                    if(!i.value.trim()) { i.closest('.input-wrapper').classList.add('error'); valid = false; }
                    else { i.closest('.input-wrapper').classList.remove('error'); }
                });
                return valid;
             }

             /* 3. 3D Card Tilt + Magnetic Physics */
             const card = document.getElementById('tiltCard');
             card.addEventListener('mousemove', (e) => {
                 const r = card.getBoundingClientRect();
                 const x = (e.clientX - r.left)/r.width - 0.5;
                 const y = (e.clientY - r.top)/r.height - 0.5;
                 gsap.to(card, { rotateX: -y * 8, rotateY: x * 8, duration: 0.5, ease: 'power2.out' });
             });
             card.addEventListener('mouseleave', () => gsap.to(card, { rotateX: 0, rotateY: 0, duration: 1, ease: 'elastic.out' }));

             const magTargets = [
                 { el: document.getElementById('magTitle'), s: 0.2 },
                 { el: document.getElementById('finalizeBtn'), s: 0.15 }
             ];
             document.addEventListener('mousemove', (e) => {
                 magTargets.forEach(m => {
                     if(!m.el) return;
                     const r = m.el.getBoundingClientRect();
                     const dx = e.clientX - (r.left + r.width/2);
                     const dy = e.clientY - (r.top + r.height/2);
                     if(Math.sqrt(dx*dx + dy*dy) < 150) {
                         gsap.to(m.el, { x: dx*m.s, y: dy*m.s, duration: 0.6 });
                     } else { gsap.to(m.el, { x: 0, y: 0, duration: 1 }); }
                 });
             });

             /* 4. Password Engine */
             document.getElementById('password').addEventListener('input', (e) => {
                 const v = e.target.value;
                 let s = 0; if(v.length>8) s++; if(/[A-Z]/.test(v)) s++; if(/[0-9]/.test(v)) s++; if(/[^A-Za-z0-9]/.test(v)) s++;
                 const labels = ["Unsafe","Weak","Medium","Strong","Elite"];
                 const colors = ["#475569","#ef4444","#f59e0b","#3b82f6","#10b981"];
                 document.getElementById('pwText').innerText = "Security: " + labels[s];
                 document.getElementById('pwText').style.color = colors[s];
                 for(let i=1; i<=4; i++) {
                     document.getElementById('b'+i).style.background = i <= s ? colors[s] : "rgba(255,255,255,0.05)";
                 }
             });

             /* 5. Tier Multiplier */
             document.querySelectorAll('.tier-card').forEach(c => c.addEventListener('click', () => {
                 document.querySelectorAll('.tier-card').forEach(t => t.classList.remove('selected'));
                 c.classList.add('selected');
             }));

             /* 6. Form Finalization */
             document.getElementById('eliteForm').addEventListener('submit', (e) => {
                 e.preventDefault();
                 if(!document.getElementById('terms').checked) return;
                 const btn = document.getElementById('finalizeBtn');
                 btn.innerHTML = '<i class="fas fa-satellite-dish fa-spin"></i> Synchronizing...';
                 btn.disabled = true;
                 setTimeout(() => {
                     document.getElementById('successModal').style.display = 'flex';
                     gsap.from('.modal-card', { scale: 0.8, opacity: 0, duration: 0.5, ease: 'back.out' });
                 }, 2500);
             });

             /* 7. File Zone */
             const dz = document.getElementById('dropZone');
             const fi = document.getElementById('profileImg');
             dz.addEventListener('click', () => fi.click());
             fi.addEventListener('change', (e) => {
                 if(e.target.files[0]) {
                     document.getElementById('fileInfo').innerText = "Confirmed: " + e.target.files[0].name;
                     document.getElementById('fileInfo').style.display = "block";
                 }
             });
        });
    </script>
</body>
</html>