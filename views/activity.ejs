<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexusSphere | SOC Command Center</title>
    
    <!-- Core Assets -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <style>
        :root {
            --p-primary: #6366f1;
            --p-secondary: #a855f7;
            --p-accent: #22d3ee;
            --p-success: #10b981;
            --p-warning: #f59e0b;
            --p-danger: #ef4444;
            --p-bg: #f1f5f9;
            --p-surface: #ffffff;
            --p-surface-glass: rgba(255, 255, 255, 0.9);
            --p-border: rgba(0, 0, 0, 0.08);
            --p-text: #020617;
            --p-text-dim: #64748b;
            --p-glow: rgba(99, 102, 241, 0.2);
            --font-mono: 'JetBrains Mono', monospace;
            --transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .dark-mode {
            --p-bg: #020617;
            --p-surface: #1e293b;
            --p-surface-glass: rgba(15, 23, 42, 0.85);
            --p-border: rgba(255, 255, 255, 0.1);
            --p-text: #f1f5f9;
            --p-text-dim: #94a3b8;
            --p-glow: rgba(99, 102, 241, 0.4);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--p-bg);
            color: var(--p-text);
            margin: 0;
            overflow-x: hidden;
            transition: background-color 0.6s ease;
        }

        /* 1. Cyber Dashboard Container */
        .cyber-dashboard {
            max-width: 1300px;
            margin: 0 auto;
            padding: 140px 1.5rem 4rem;
            position: relative;
            z-index: 5;
            opacity: 0;
        }

        /* 2. Command Center Header */
        .soc-header {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 2rem;
            margin-bottom: 4rem;
        }

        .soc-main-card {
            background: var(--p-surface-glass);
            border: 2px solid var(--p-border);
            border-radius: 36px;
            padding: 2.5rem;
            backdrop-filter: blur(30px);
            position: relative;
            overflow: hidden;
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.1);
        }

        .live-status {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 2rem;
            font-family: var(--font-mono);
        }

        .pulse-dot {
            width: 12px; height: 12px;
            background: var(--p-success);
            border-radius: 50%;
            box-shadow: 0 0 15px var(--p-success);
            animation: pulse-ring 2s infinite;
        }

        @keyframes pulse-ring {
            0% { transform: scale(0.8); opacity: 0.5; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { transform: scale(1.1); opacity: 1; box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { transform: scale(0.8); opacity: 0.5; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        .terminal-text { font-weight: 700; color: var(--p-success); font-size: 0.9rem; letter-spacing: 2px; }

        .heatmap-container { height: 120px; width: 100%; display: flex; align-items: flex-end; gap: 4px; margin-top: 1rem; }
        .heat-bar { 
            flex: 1; 
            background: linear-gradient(to top, var(--p-primary), var(--p-secondary)); 
            border-radius: 4px 4px 0 0;
            transition: height 1s ease;
            opacity: 0.8;
            position: relative;
        }
        .heat-bar:hover { opacity: 1; transform: scaleX(1.1); }

        /* Stat Grid Small */
        .soc-stats-mini {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        .mini-card {
            background: var(--p-surface-glass);
            border: 1px solid var(--p-border);
            border-radius: 24px;
            padding: 1.5rem;
            display: flex; align-items: center; gap: 1.2rem;
            transition: var(--transition);
        }
        .mini-card:hover { transform: translateX(-10px); border-color: var(--p-primary); }
        .mini-icon { font-size: 1.5rem; color: var(--p-primary); }

        /* 3. Interactive Timeline Scroll */
        .nexus-path-container {
            position: relative;
            padding-left: 5rem;
            margin-top: 4rem;
        }

        .nexus-line-svg {
            position: absolute;
            left: 20px; top: 0;
            width: 8px; height: 100%;
            pointer-events: none;
        }

        .nexus-line-path {
            fill: none;
            stroke: var(--p-primary);
            stroke-width: 4;
            stroke-dasharray: 10, 5;
            stroke-linecap: round;
            opacity: 0.2;
        }

        .nexus-line-progress {
            fill: none;
            stroke: var(--p-primary);
            stroke-width: 4;
            stroke-linecap: round;
            filter: drop-shadow(0 0 8px var(--p-primary));
        }

        /* 4. Cyber Cards */
        .cyber-log-item { margin-bottom: 3.5rem; position: relative; }
        
        .cyber-marker {
            position: absolute;
            left: -5.1rem; top: 0;
            width: 58px; height: 58px;
            background: var(--p-bg);
            border: 4px solid var(--p-border);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            z-index: 10;
            transition: var(--transition);
            color: var(--p-text-dim);
            font-size: 1.3rem;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .cyber-log-item.active-node .cyber-marker {
            border-color: var(--p-primary);
            color: var(--p-primary);
            box-shadow: 0 0 25px var(--p-glow);
            transform: scale(1.1);
        }

        .cyber-card {
            background: var(--p-surface-glass);
            border: 2px solid var(--p-border);
            border-radius: 30px;
            padding: 2.2rem;
            backdrop-filter: blur(20px);
            transition: var(--transition);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
        }

        .cyber-card:hover { 
            transform: translateX(15px) scale(1.01); 
            border-color: var(--p-primary);
            box-shadow: 20px 20px 50px -15px var(--p-glow);
        }

        .cyber-grid { display: grid; grid-template-columns: 1fr auto; gap: 1rem; margin-bottom: 1.5rem; }
        .cyber-title { font-weight: 800; font-size: 1.4rem; color: var(--p-text); margin: 0; line-height: 1.2; }
        .cyber-meta { font-family: var(--font-mono); font-size: 0.8rem; color: var(--p-primary); opacity: 0.8; }

        .cyber-content { color: var(--p-text-dim); font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.5rem; }
        
        .log-actions { display: flex; gap: 1rem; border-top: 1px solid var(--p-border); padding-top: 1.5rem; }
        .action-btn { 
            background: rgba(0,0,0,0.03); border: 1px solid var(--p-border); 
            padding: 0.5rem 1rem; border-radius: 12px; font-size: 0.8rem; font-weight: 700;
            color: var(--p-text-dim); cursor: pointer; transition: 0.3s;
            display: flex; align-items: center; gap: 0.5rem;
        }
        .action-btn:hover { background: var(--p-primary); color: #fff; border-color: var(--p-primary); }

        /* Security Glitch Effect */
        .type-security .cyber-card:hover { animation: subtle-glitch 0.4s infinite; }
        @keyframes subtle-glitch {
            0% { transform: translateX(15px) skew(0deg); }
            20% { transform: translateX(17px) skew(1deg); }
            40% { transform: translateX(14px) skew(-1deg); }
            100% { transform: translateX(15px) skew(0deg); }
        }

        /* 5. Floating UI Elements */
        .data-orb {
            position: fixed; width: 6px; height: 6px; background: var(--p-primary);
            border-radius: 50%; opacity: 0.2; pointer-events: none; z-index: -1;
        }

        /* Detail Modal Pro */
        .nexus-modal {
            background: var(--p-bg); border: 2px solid var(--p-primary);
            border-radius: 40px; width: 95%; max-width: 750px; padding: 4rem;
            position: relative; box-shadow: 0 50px 100px rgba(0,0,0,0.4);
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        @media (max-width: 992px) {
            .soc-header { grid-template-columns: 1fr; }
            .soc-stats-mini { grid-template-columns: 1fr 1fr; }
        }
        @media (max-width: 768px) {
            .cyber-dashboard { padding-top: 120px; }
            .nexus-path-container { padding-left: 2.5rem; }
            .cyber-marker { left: -3.2rem; width: 44px; height: 44px; font-size: 1rem; }
            .nexus-line-svg { left: 16px; }
            .soc-stats-mini { grid-template-columns: 1fr; }
            .cyber-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="<%= typeof theme !== 'undefined' ? theme : '' %>">

<%- include("../utils/header") %>
<%- include("side"); %>

<!-- Immersive Elements -->
<div id="particleContainer"></div>

<main id="main">
    <div class="cyber-dashboard" id="dash">
        
        <!-- SOC Command Center -->
        <header class="soc-header">
            <div class="soc-main-card">
                <div class="live-status">
                    <div class="pulse-dot"></div>
                    <span class="terminal-text">SITE_OPERATIONS_CENTER_VER_4.0 // ACTIVE_SCAN</span>
                    <span id="terminalClock" style="margin-left: auto; color: var(--p-text-dim); font-weight: 800;">00:00:00</span>
                </div>
                <h2 style="font-weight: 900; font-size: 2.5rem; margin-bottom: 0.5rem; letter-spacing: -2px;">Activity Density</h2>
                <p style="color: var(--p-text-dim); margin-bottom: 2rem;">Real-time telemetry of neural protocols and system transactions.</p>
                
                <div class="heatmap-container" id="heatmap">
                    <!-- Dynamic Bars via JS -->
                </div>
            </div>

            <div class="soc-stats-mini">
                <div class="mini-card" style="border-right: 4px solid var(--p-danger);">
                    <div class="mini-icon" style="color: var(--p-danger);"><i class="fas fa-biohazard"></i></div>
                    <div>
                        <div style="font-size: 1.5rem; font-weight: 900;"><%= recent_activity ? recent_activity.filter(a => (a.activity||'').toLowerCase().includes('security')).length : 0 %></div>
                        <div style="font-size: 0.75rem; color: var(--p-text-dim); text-transform: uppercase; font-weight: 800;">Threats Blocked</div>
                    </div>
                </div>
                <div class="mini-card" style="border-right: 4px solid var(--p-primary);">
                    <div class="mini-icon"><i class="fas fa-layer-group"></i></div>
                    <div>
                        <div style="font-size: 1.5rem; font-weight: 900;"><%= recent_activity ? recent_activity.length : 0 %></div>
                        <div style="font-size: 0.75rem; color: var(--p-text-dim); text-transform: uppercase; font-weight: 800;">Total Pkts Scanned</div>
                    </div>
                </div>
                <div class="mini-card" style="border-right: 4px solid var(--p-success);">
                    <div class="mini-icon" style="color: var(--p-success);"><i class="fas fa-microchip"></i></div>
                    <div>
                        <div style="font-size: 1.5rem; font-weight: 900;">0.04ms</div>
                        <div style="font-size: 0.75rem; color: var(--p-text-dim); text-transform: uppercase; font-weight: 800;">Avg Neural Sync</div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Search Nexus -->
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 5rem;">
            <div style="position: relative; flex: 1;">
                <i class="fas fa-search" style="position: absolute; left: 1.5rem; top: 50%; transform: translateY(-50%); color: var(--p-primary);"></i>
                <input type="text" id="nexusSearch" placeholder="Initiate global telemetry search..." style="width: 100%; border-radius: 20px; border: 2px solid var(--p-border); padding: 1.2rem 1rem 1.2rem 3.5rem; background: var(--p-surface-glass); color: var(--p-text); font-weight: 700; font-size: 1.1rem; outline: none; transition: 0.3s;">
            </div>
            <button class="action-btn" style="padding: 1.2rem 2rem; border-radius: 20px; font-size: 1rem; background: var(--p-primary); color: #fff;"><i class="fas fa-filter"></i> Analytics</button>
        </div>

        <!-- Scroll Timeline Section -->
        <div class="nexus-path-container">
            <svg class="nexus-line-svg">
                <path id="nexusLine" class="nexus-line-path" d="M 4 0 L 4 5000"></path>
                <path id="nexusProgress" class="nexus-line-progress" d="M 4 0 L 4 0"></path>
            </svg>

            <div id="activityFlow">
                <% if(recent_activity && recent_activity.length > 0) { 
                    const pageQuery = typeof query !== 'undefined' && query.page ? query.page : 1;
                    const perPage = 25;
                    const currentPage = parseInt(pageQuery) || 1;
                    const paginated = recent_activity.slice((currentPage-1)*perPage, currentPage*perPage);
                    const totalPages = Math.ceil(recent_activity.length / perPage);

                    paginated.forEach((a, index) => { 
                        let type = 'system';
                        let icon = 'fa-info-circle';
                        const msg = (a.activity || '').toLowerCase();
                        if(msg.includes('login') || msg.includes('sign in') || msg.includes('otp')) { type = 'security'; icon = 'fa-user-shield'; }
                        else if(msg.includes('deposit') || msg.includes('withdraw') || msg.includes('purchase')) { type = 'finance'; icon = 'fa-satellite-dish'; }
                        else if(msg.includes('update')) { type = 'update'; icon = 'fa-sync-alt'; }
                %>
                    <div class="cyber-log-item type-<%= type %>" data-type="<%= type %>">
                        <div class="cyber-marker"><i class="fas <%= icon %>"></i></div>
                        <div class="cyber-card" onclick="openDetails('<%= a.activity %>', '<%= a.activity_detail %>', '<%= a.createdAt %>')">
                            <div class="cyber-grid">
                                <div>
                                    <h3 class="cyber-title"><%= a.activity %></h3>
                                    <span class="cyber-meta">PROC_HASH_0x<%= Math.random().toString(16).substr(2, 8).toUpperCase() %> // TYPE_<%= type.toUpperCase() %></span>
                                </div>
                                <div class="log-time"><%= new Date(a.createdAt).toLocaleString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %></div>
                            </div>
                            <p class="cyber-content">
                                <%= a.activity_detail && a.activity_detail !== 'No Activity Is Done' ? a.activity_detail : 'Asynchronous operation finalized. Telemetry data archived in Nexus node.' %>
                            </p>
                            <div class="log-actions">
                                <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--p-success); background: rgba(16, 185, 129, 0.1); padding: 4px 10px; border-radius: 6px;">RISK_LOW</span>
                                <div style="margin-left: auto; display: flex; gap: 0.5rem;">
                                    <button class="action-btn"><i class="fas fa-copy"></i></button>
                                    <button class="action-btn"><i class="fas fa-terminal"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
                
                <% if(totalPages > 1) { %>
                    <nav class="pagination">
                        <% for(let i=1; i <= totalPages; i++) { %>
                            <a href="?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                        <% } %>
                    </nav>
                <% } %>
                
                <% } else { %>
                    <div style="text-align: center; padding: 10rem 2rem; color: var(--p-text-dim);">
                        <i class="fas fa-radar" style="font-size: 6rem; opacity: 0.05; animation: pulse-ring 3s infinite;"></i>
                        <h2 style="font-weight: 900; letter-spacing: -2px; margin-top: 2rem;">No Telemetry Signal</h2>
                        <p>Waiting for Nexus node to broadcast activity packets...</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>



<%- include("../utils/footer") %>
</main>

<!-- Nexus Detail Overlay -->
<div id="detailOverlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2000; background: rgba(0,0,0,0.4); backdrop-filter: blur(25px); display: none; align-items: center; justify-content: center;" onclick="closeDetails()">
    <div class="nexus-modal" onclick="event.stopPropagation()">
        <button onclick="closeDetails()" style="position: absolute; right: 3rem; top: 3rem; border: none; background: var(--p-surface); width: 60px; height: 60px; border-radius: 50%; color: var(--p-text); cursor: pointer; font-size: 1.5rem; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 30px rgba(0,0,0,0.1);"><i class="fas fa-times"></i></button>
        <div style="font-family: var(--font-mono); color: var(--p-primary); font-weight: 700; margin-bottom: 1rem; font-size: 0.9rem;">PROTOCOL_INSPECTOR_V1</div>
        <h2 id="modalTitle" style="font-weight: 950; font-size: 3rem; letter-spacing: -3px; color: var(--p-text); margin-bottom: 2.5rem; line-height: 1;"></h2>
        
        <div style="background: var(--p-bg); border: 2px solid var(--p-border); padding: 3rem; border-radius: 40px;">
            <div id="modalDetail" style="font-size: 1.25rem; line-height: 2; color: var(--p-text-dim); margin-bottom: 3rem;"></div>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
                <div>
                    <div style="font-size: 0.7rem; color: var(--p-primary); font-weight: 900; letter-spacing: 2px; text-transform: uppercase;">Node State</div>
                    <div style="font-weight: 800; font-size: 1rem; color: var(--p-success);">DECRYPTED</div>
                </div>
                <div>
                    <div style="font-size: 0.7rem; color: var(--p-primary); font-weight: 900; letter-spacing: 2px; text-transform: uppercase;">Confidence</div>
                    <div style="font-weight: 800; font-size: 1rem;">99.4%</div>
                </div>
                <div>
                    <div style="font-size: 0.7rem; color: var(--p-primary); font-weight: 900; letter-spacing: 2px; text-transform: uppercase;">Timestamp</div>
                    <div id="modalTime" style="font-weight: 800; font-size: 1rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // 1. Initial Orchestration
        gsap.to('.cyber-dashboard', { opacity: 1, duration: 1.5, ease: 'power2.out' });
        
        // 2. Dynamic Clock
        setInterval(() => {
            const now = new Date();
            document.getElementById('terminalClock').innerText = now.toTimeString().split(' ')[0];
        }, 1000);

        // 3. SVG Timeline Drawing
        gsap.registerPlugin(ScrollTrigger);
        const dashHeight = document.getElementById('dash').offsetHeight;
        document.getElementById('nexusLine').setAttribute('d', `M 4 0 L 4 ${dashHeight}`);
        
        gsap.to('#nexusProgress', {
            attr: { d: `M 4 0 L 4 ${dashHeight}` },
            scrollTrigger: {
                trigger: '#activityFlow',
                start: 'top 50%',
                end: 'bottom 50%',
                scrub: 1.5
            }
        });

        // 4. Activity Heatmap Simulator
        const heatmap = document.getElementById('heatmap');
        for(let i=0; i<30; i++) {
            const bar = document.createElement('div');
            bar.className = 'heat-bar';
            const h = Math.random() * 100 + 10;
            bar.style.height = '0%';
            heatmap.appendChild(bar);
            gsap.to(bar, { height: `${h}%`, duration: 1.5, delay: i * 0.05, ease: 'elastic.out(1, 0.5)' });
        }

        // 5. Scroll Interaction for Nodes
        document.querySelectorAll('.cyber-log-item').forEach(item => {
            ScrollTrigger.create({
                trigger: item,
                start: 'top 60%',
                onEnter: () => item.classList.add('active-node'),
                onLeaveBack: () => item.classList.remove('active-node')
            });
        });

        // 6. Particle Generation
        const particleContainer = document.getElementById('particleContainer');
        for(let i=0; i<40; i++) {
            const orb = document.createElement('div');
            orb.className = 'data-orb';
            orb.style.left = `${Math.random() * 100}%`;
            orb.style.top = `${Math.random() * 100}%`;
            particleContainer.appendChild(orb);
            
            gsap.to(orb, {
                y: '-20vh', x: `${Math.random() * 50 - 25}px`,
                duration: Math.random() * 10 + 5,
                repeat: -1, ease: 'none', delay: Math.random() * 5
            });
        }

        // 7. Search Integration
        const nexusSearch = document.getElementById('nexusSearch');
        nexusSearch.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.cyber-log-item').forEach(item => {
                const text = item.innerText.toLowerCase();
                if(text.includes(term)) {
                    gsap.to(item, { display: 'block', opacity: 1, scale: 1, duration: 0.4 });
                } else {
                    gsap.to(item, { display: 'none', opacity: 0, scale: 0.9, duration: 0.3 });
                }
            });
        });
    });

    function openDetails(title, detail, time) {
        document.getElementById('modalTitle').innerText = title;
        document.getElementById('modalDetail').innerText = detail && detail !== 'No Activity Is Done' ? detail : 'Neural packet inspection verified. Operation successfully routed through Nexus protocol layers.';
        document.getElementById('modalTime').innerText = new Date(time).toLocaleTimeString();
        
        const overlay = document.getElementById('detailOverlay');
        overlay.style.display = 'flex';
        gsap.fromTo('.nexus-modal', 
            { y: 150, rotateX: 20, opacity: 0, scale: 0.8 }, 
            { y: 0, rotateX: 0, opacity: 1, scale: 1, duration: 1, ease: 'expo.out' }
        );
    }

    function closeDetails() {
        gsap.to('.nexus-modal', { y: 50, opacity: 0, scale: 0.9, duration: 0.5, ease: 'power4.in', onComplete: () => {
            document.getElementById('detailOverlay').style.display = 'none';
        }});
    }
</script>



</body>
</html>