<!-- utils/footer.ejs -->
<style>
  /* Scoped Footer Styles - Isolated to prevent breaking other pages */
  .custom-global-footer {
    --f-bg: #ffffff;
    --f-text: #1e293b;
    --f-muted: #64748b;
    --f-border: #e2e8f0;
    --f-primary: #4361ee;
    --f-accent: #4cc9f0;
    --f-input-bg: #f8fafc;
    
    background: var(--f-bg);
    color: var(--f-text);
    border-top: 1px solid var(--f-border);
    padding: 70px 5% 30px;
    font-family: 'Roboto', 'Poppins', sans-serif;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
    z-index: 50;
    margin-top: 50px;
    /* margin-left is set globally in header.ejs via CSS variable */
  }

  /* Responsive footer width - controlled by header.ejs global rules */
  @media (max-width: 991.98px) {
    .custom-global-footer {
      /* margin-left reset is handled in header.ejs */
    }
  }

  /* Dark Mode Sync directly linked to the header button toggling body.dark-mode */
  body.dark-mode .custom-global-footer {
    --f-bg: #0f172a;
    --f-text: #f8fafc;
    --f-muted: #94a3b8;
    --f-border: #1e293b;
    --f-primary: #4895ef;
    --f-input-bg: #1e293b;
  }

  /* Animated Glowing Top Border */
  .custom-global-footer::before {
    content: '';
    position: absolute;
    top: 0; 
    left: 0; 
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--f-primary), var(--f-accent), #f72585, var(--f-primary));
    background-size: 300% 100%;
    animation: footerGradientFlow 6s ease-in-out infinite;
  }

  @keyframes footerGradientFlow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Footer Layout Grid */
  .f-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  /* Column Typography */
  .f-col h4 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 25px;
    color: var(--f-text);
    position: relative;
    display: inline-block;
  }

  .f-col h4::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 30px;
    height: 2px;
    background: var(--f-primary);
    transition: width 0.3s ease;
  }

  .f-col:hover h4::after {
    width: 100%;
  }

  .f-col p {
    color: var(--f-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  /* Quick Links with Hover Strikethrough/Slide Animation */
  .f-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .f-links li {
    margin-bottom: 12px;
  }

  .f-links a {
    color: var(--f-muted);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
  }

  /* Animated Arrow on Links */
  .f-links a::before {
    content: '→';
    font-size: 0.8rem;
    color: var(--f-primary);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
    margin-right: 0px;
    display: inline-block;
    width: 0;
  }

  .f-links a:hover {
    color: var(--f-primary);
    transform: translateX(5px);
  }

  .f-links a:hover::before {
    opacity: 1;
    transform: translateX(0);
    margin-right: 8px;
    width: 15px;
  }

  /* Social Icons Bouncing Animation */
  .f-socials {
    display: flex;
    gap: 15px;
    margin-top: 20px;
  }

  .f-social-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--f-input-bg);
    border: 1px solid var(--f-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--f-text);
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }

  .f-social-btn::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--f-primary);
    transition: all 0.3s ease;
    z-index: 0;
  }

  .f-social-btn:hover::before {
    top: 0;
  }

  .f-social-btn i {
    z-index: 1;
    transition: color 0.3s ease;
  }

  .f-social-btn:hover i {
    color: #ffffff;
    transform: scale(1.2);
  }

  .f-social-btn:hover {
    transform: translateY(-5px);
    border-color: var(--f-primary);
    box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
  }

  /* Subscribe Box Animation */
  .f-subscribe {
    display: flex;
    margin-top: 15px;
    position: relative;
  }

  .f-input {
    flex: 1;
    padding: 12px 15px;
    border: 1px solid var(--f-border);
    background: var(--f-input-bg);
    color: var(--f-text);
    border-radius: 8px 0 0 8px;
    outline: none;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .f-input:focus {
    border-color: var(--f-primary);
    box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
  }

  .f-btn {
    padding: 12px 20px;
    background: var(--f-primary);
    color: white;
    border: none;
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .f-btn:hover {
    background: var(--f-accent);
  }

  /* Bottom Copyright Area */
  .f-bottom {
    margin-top: 60px;
    padding-top: 25px;
    border-top: 1px solid var(--f-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--f-muted);
    font-size: 0.9rem;
  }

  .f-bottom-links a {
    color: var(--f-muted);
    text-decoration: none;
    margin-left: 20px;
    transition: color 0.3s ease;
  }

  .f-bottom-links a:hover {
    color: var(--f-primary);
  }

  @media (max-width: 768px) {
    .f-bottom {
      flex-direction: column;
      gap: 15px;
      text-align: center;
    }
    .f-bottom-links a {
      margin: 0 10px;
    }
  }
</style>

